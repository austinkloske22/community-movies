---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
import { languages } from '../i18n/ui';
import LanguagePicker from './LanguagePicker.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Locations for the schedule dropdown
const locations = [
  {
    id: 'haarlem',
    name: t('schedule.locationHaarlem'),
    park: null,
    href: '/programma/haarlem',
    active: true
  },
  {
    id: 'tiel',
    name: t('schedule.locationTiel'),
    park: null,
    href: '/programma/tiel',
    active: true
  },
  {
    id: 'ijmuiden',
    name: t('schedule.locationIJmuiden'),
    park: null,
    href: '/programma/ijmuiden',
    active: true
  },
];

// Same paths for all languages (Dutch path names)
const navItems = [
  { href: '/', label: t('nav.home'), hasDropdown: false },
  { href: '/programma', label: t('nav.schedule'), hasDropdown: true },
  { href: '/over-ons', label: t('nav.about'), hasDropdown: false },
  { href: '/voor-gemeenten', label: t('nav.municipalities'), hasDropdown: false },
  { href: '/contact', label: t('nav.contact'), hasDropdown: false },
];
---

<header class="header" dir="ltr">
  <div class="container">
    <nav class="nav">
      <a href={getLocalizedPath('/', lang)} class="logo">
        <img src="/images/brand/icon-logo-clear-background.png" alt="Nelsons Film" class="logo-icon" />
        <span class="logo-text">Nelsons Film</span>
      </a>

      <div class="mobile-actions">
        <div class="mobile-lang-picker">
          <LanguagePicker />
        </div>
        <button class="mobile-menu-btn" aria-label="Menu" aria-expanded="false">
          <span class="hamburger"></span>
        </button>
      </div>

      <ul class="nav-links">
        {navItems.map((item) => (
          <li class={item.hasDropdown ? 'has-dropdown' : ''}>
            {item.hasDropdown ? (
              <>
                <a href={getLocalizedPath(item.href, lang)}
                   class="nav-link dropdown-toggle"
                   aria-haspopup="true"
                   aria-expanded="false">
                  {item.label}
                  <svg class="dropdown-arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M6 9l6 6 6-6"/>
                  </svg>
                </a>
                <div class="dropdown-menu" role="menu">
                  <div class="dropdown-header">
                    <span class="dropdown-title">{t('schedule.locations')}</span>
                  </div>
                  {locations.map((location) => (
                    <a href={getLocalizedPath(location.href!, lang)} class="dropdown-item" role="menuitem">
                      <span class="location-name">{location.name}</span>
                    </a>
                  ))}
                  <a href={getLocalizedPath('/voor-gemeenten', lang)} class="dropdown-cta" role="menuitem">
                    {t('nav.municipalityBanner')}
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </a>
                </div>
              </>
            ) : (
              <a href={getLocalizedPath(item.href, lang)} class="nav-link">
                {item.label}
              </a>
            )}
          </li>
        ))}
        <li class="lang-picker-wrapper">
          <LanguagePicker />
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(27, 47, 74, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-md) 0;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
  }

  .logo:hover {
    color: var(--color-gold);
  }

  .logo-icon {
    height: 32px;
    width: 32px;
    object-fit: contain;
    border-radius: 4px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    list-style: none;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 4px;
    color: var(--color-text-muted);
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-gold);
  }

  .dropdown-arrow {
    transition: transform var(--transition-fast);
  }

  /* Dropdown styles */
  .has-dropdown {
    position: relative;
  }

  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    min-width: 280px;
    background: var(--color-card);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    padding: var(--space-sm);
    opacity: 0;
    visibility: hidden;
    transition: all var(--transition-fast);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }

  .has-dropdown[data-open="true"] > .dropdown-menu,
  .has-dropdown:focus-within > .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .has-dropdown[data-open="true"] > .nav-link > .dropdown-arrow,
  .has-dropdown:focus-within > .nav-link > .dropdown-arrow {
    transform: rotate(180deg);
  }

  /* Hover is a convenience on real pointer devices only — not on touch. */
  @media (hover: hover) and (pointer: fine) {
    .has-dropdown:hover > .dropdown-menu {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(0);
    }
    .has-dropdown:hover > .nav-link > .dropdown-arrow {
      transform: rotate(180deg);
    }
  }

  .dropdown-header {
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    margin-bottom: var(--space-xs);
  }

  .dropdown-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md);
    border-radius: var(--radius-md);
    color: var(--color-text);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .dropdown-item:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-gold);
  }

  .dropdown-item .location-name {
    font-weight: 500;
    font-size: 0.95rem;
  }

  .dropdown-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: var(--space-md);
    margin-top: var(--space-xs);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--color-accent);
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .dropdown-cta:hover {
    color: var(--color-accent-light);
  }

  .mobile-actions {
    display: none;
    align-items: center;
    gap: var(--space-md);
  }

  .mobile-lang-picker {
    display: none;
  }

  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-sm);
  }

  .hamburger,
  .hamburger::before,
  .hamburger::after {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text);
    transition: all var(--transition-fast);
  }

  .hamburger {
    position: relative;
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    inset-inline-start: 0;
  }

  .hamburger::before {
    top: -8px;
  }

  .hamburger::after {
    top: 8px;
  }

  @media (max-width: 768px) {
    .mobile-actions {
      display: flex;
    }

    .mobile-lang-picker {
      display: block;
    }

    .mobile-menu-btn {
      display: block;
    }

    .nav-links {
      position: fixed;
      top: 60px;
      left: 0;
      right: 0;
      flex-direction: column;
      background: var(--color-bg);
      padding: var(--space-lg);
      gap: var(--space-md);
      transform: translateY(-100%);
      opacity: 0;
      visibility: hidden;
      transition: all var(--transition-normal);
      max-height: calc(100vh - 60px);
      overflow-y: auto;
    }

    .nav-links.open {
      transform: translateY(0);
      opacity: 1;
      visibility: visible;
    }

    /* Mobile dropdown - always visible when menu is open */
    .has-dropdown .dropdown-menu {
      position: static;
      transform: none;
      opacity: 1;
      visibility: visible;
      min-width: 100%;
      margin-top: var(--space-sm);
      box-shadow: none;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .dropdown-arrow {
      transform: rotate(180deg);
    }

    /* Hide language picker inside mobile menu since it's now in the header */
    .lang-picker-wrapper {
      display: none;
    }
  }
</style>

<script>
  const menuBtn = document.querySelector<HTMLButtonElement>('.mobile-menu-btn');
  const navLinks = document.querySelector<HTMLUListElement>('.nav-links');

  menuBtn?.addEventListener('click', () => {
    const isOpen = navLinks?.classList.toggle('open');
    menuBtn.setAttribute('aria-expanded', String(isOpen));
  });

  // --- Dropdown disclosure (click + keyboard, not hover-only) ---
  const dropdowns = document.querySelectorAll<HTMLLIElement>('.has-dropdown');
  const isTouch = window.matchMedia('(hover: none), (pointer: coarse)').matches;

  const closeAll = (except?: HTMLLIElement) => {
    dropdowns.forEach((d) => {
      if (d === except) return;
      d.dataset.open = 'false';
      const toggle = d.querySelector<HTMLElement>('.dropdown-toggle');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  };

  dropdowns.forEach((dd) => {
    const toggle = dd.querySelector<HTMLAnchorElement>('.dropdown-toggle');
    if (!toggle) return;

    toggle.addEventListener('click', (e) => {
      // On desktop, tapping the parent link should still navigate — but on
      // touch/coarse pointers, first tap opens the menu, second tap navigates.
      const open = dd.dataset.open === 'true';
      if (isTouch && !open) {
        e.preventDefault();
        closeAll(dd);
        dd.dataset.open = 'true';
        toggle.setAttribute('aria-expanded', 'true');
      }
    });

    toggle.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ' || e.key === 'ArrowDown') {
        e.preventDefault();
        closeAll(dd);
        dd.dataset.open = 'true';
        toggle.setAttribute('aria-expanded', 'true');
        // Focus first menu item so keyboard users can arrow through.
        const first = dd.querySelector<HTMLAnchorElement>('.dropdown-menu a');
        first?.focus();
      }
    });
  });

  // Escape closes any open dropdown and returns focus to its toggle.
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    const openDd = document.querySelector<HTMLLIElement>('.has-dropdown[data-open="true"]');
    if (!openDd) return;
    openDd.dataset.open = 'false';
    const toggle = openDd.querySelector<HTMLElement>('.dropdown-toggle');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.focus();
  });

  // Click anywhere outside closes open dropdowns.
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.closest('.has-dropdown')) return;
    closeAll();
  });
</script>
