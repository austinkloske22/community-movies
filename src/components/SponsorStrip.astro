---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  variant?: 'full' | 'strip';
  class?: string;
}

const { variant = 'strip', class: extraClass = '' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Sponsor {
  name: string;
  url: string;
  /** Domain used to fetch the favicon. Usually url without the protocol. */
  domain: string;
}

// Favicons come from Google's s2 service (same one the About press links
// use). Reliable, cached, always current — no repo files to keep updated.
// If you want to swap in a handcrafted logo for any sponsor later, drop an
// SVG in /public/images/sponsors/{slug}.svg and switch the img src below.
const sponsors: Sponsor[] = [
  { name: 'COA',              url: 'https://www.coa.nl',          domain: 'coa.nl' },
  { name: 'Gemeente Haarlem', url: 'https://www.haarlem.nl',      domain: 'haarlem.nl' },
  { name: 'BUURT',            url: 'https://buurtamsterdam.nl',   domain: 'buurtamsterdam.nl' },
  { name: 'Cronjé',           url: 'https://cronje.nl',           domain: 'cronje.nl' },
  { name: 'De Snuffelmug',    url: 'https://desnuffelmug.nl',     domain: 'desnuffelmug.nl' },
  { name: 'HBP Hoorne',       url: 'https://hoornevastgoed.nl',   domain: 'hoornevastgoed.nl' },
  { name: 'Duizend1',         url: 'https://duizend1.nl',         domain: 'duizend1.nl' },
];

const faviconSrc = (domain: string) => `https://www.google.com/s2/favicons?domain=${domain}&sz=128`;
---

<section class:list={['sponsor-strip', `variant-${variant}`, extraClass]}>
  {variant === 'full' && (
    <header class="sponsor-head">
      <h2>{t('sponsors.title')}</h2>
      <p>{t('sponsors.subtitle')}</p>
    </header>
  )}

  <ul class="sponsor-list">
    {sponsors.map((s) => (
      <li class="sponsor-item">
        <a href={s.url} target="_blank" rel="noopener" class="sponsor-card" aria-label={s.name}>
          <img src={faviconSrc(s.domain)}
               alt=""
               width="40" height="40"
               loading="lazy"
               class="sponsor-favicon" />
          <span class="sponsor-name">{s.name}</span>
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .sponsor-strip {
    position: relative;
  }

  .variant-full {
    max-width: 1100px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-md);
    text-align: center;
  }

  .sponsor-head {
    margin-bottom: var(--space-lg);
  }

  .sponsor-head h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: var(--space-sm);
  }

  .sponsor-head p {
    color: var(--color-text-muted);
    max-width: 520px;
    margin: 0 auto;
  }

  .sponsor-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    justify-content: center;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sponsor-item {
    flex: 0 0 auto;
  }

  .sponsor-card {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 10px 16px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    color: var(--color-text);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .sponsor-card:hover {
    background: rgba(242, 199, 92, 0.06);
    border-color: rgba(242, 199, 92, 0.4);
    color: var(--color-text);
    transform: translateY(-1px);
  }

  .sponsor-card:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }

  .sponsor-favicon {
    width: 24px;
    height: 24px;
    border-radius: 4px;
    flex-shrink: 0;
    background: rgba(255, 255, 255, 0.04);
  }

  .sponsor-name {
    font-size: 0.9rem;
    font-weight: 500;
    white-space: nowrap;
  }

  /* Full variant (About page) — a bit larger, centred under a heading */
  .variant-full .sponsor-list {
    gap: var(--space-md);
  }

  .variant-full .sponsor-card {
    padding: 12px 20px;
  }

  .variant-full .sponsor-favicon {
    width: 28px;
    height: 28px;
  }

  .variant-full .sponsor-name {
    font-size: 0.95rem;
  }

  @media (max-width: 640px) {
    .sponsor-card {
      padding: 8px 14px;
    }
    .sponsor-favicon {
      width: 20px;
      height: 20px;
    }
    .sponsor-name {
      font-size: 0.85rem;
    }
  }
</style>
