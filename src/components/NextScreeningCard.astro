---
import Icon from './Icon.astro';
import { useTranslations } from '../i18n/utils';
import type { Movie } from '../lib/sheets';
import { buildIcs, slugifyForFilename } from '../lib/ics.ts';

interface Props {
  movie: Movie;
  lang: 'nl' | 'en' | 'ara';
  pageUrl: string;
}

const { movie, lang, pageUrl } = Astro.props;
const t = useTranslations(lang);

const localeMap: Record<string, string> = { nl: 'nl-NL', en: 'en-GB', ara: 'ar-SA' };
const locale = localeMap[lang] || 'en-GB';
const dateObj = new Date(movie.date);
const dayNum = dateObj.toLocaleDateString(locale, { day: 'numeric' });
const monthShort = dateObj.toLocaleDateString(locale, { month: 'short' }).replace(/\.$/, '');
const weekdayShort = dateObj.toLocaleDateString(locale, { weekday: 'short' }).replace(/\.$/, '');

const icsText = buildIcs({
  title: `Nelsons Film — ${movie.title}`,
  date: movie.date,
  time: movie.time,
  location: movie.location || 'Nelson Mandelapark, Haarlem',
  description: lang === 'nl' ? movie.descriptionNl : movie.descriptionEn,
  url: pageUrl,
});
const icsFilename = `nelsonsfilm-${slugifyForFilename(movie.title)}-${movie.date.replace(/-/g, '')}.ics`;

const waDateText = dateObj.toLocaleDateString(locale, { day: 'numeric', month: 'long' });
const waMessage = `${t('share.whatsappPrefix')} ${movie.title} — ${waDateText} · ${pageUrl}`;
const whatsappHref = `https://wa.me/?text=${encodeURIComponent(waMessage)}`;
---

<aside class="ns-card">
  <div class="ns-date">
    <span class="ns-date-day">{dayNum}</span>
    <span class="ns-date-month">{monthShort}</span>
    <span class="ns-date-dow">{weekdayShort}</span>
  </div>

  <div class="ns-body">
    <div class="ns-badge">{t('schedule.nextScreening')}</div>
    <h2 class="ns-title">{movie.title}</h2>
    <div class="ns-meta">
      <span class="ns-meta-item"><Icon name="clock" size={14} />{movie.time}</span>
      <span class="ns-meta-item"><Icon name="map-pin" size={14} />{movie.location || 'Nelson Mandelapark'}</span>
    </div>
    <div class="ns-actions">
      <button type="button" class="ns-action action-calendar"
              data-ics={icsText}
              data-ics-filename={icsFilename}
              aria-label={t('share.addToCalendar')}>
        <Icon name="calendar" size={16} />
        <span>{t('share.addToCalendar')}</span>
      </button>
      <a href={whatsappHref} target="_blank" rel="noopener" class="ns-action"
         aria-label={t('share.whatsapp')}>
        <Icon name="share-2" size={16} />
        <span>{t('share.whatsapp')}</span>
      </a>
      <a href="#rsvp-panel" class="ns-action ns-action-primary ns-rsvp-scroll">
        <Icon name="users" size={16} />
        <span>{t('rsvp.expandCta')}</span>
      </a>
    </div>
  </div>
</aside>

<style>
  .ns-card {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-lg);
    padding: var(--space-lg);
    background: rgba(27, 47, 74, 0.72);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(239, 230, 216, 0.12);
    border-radius: var(--radius-lg);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
    align-items: center;
  }

  .ns-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-md) var(--space-lg);
    background: rgba(215, 110, 77, 0.15);
    border: 1px solid rgba(215, 110, 77, 0.4);
    border-radius: var(--radius-md);
    min-width: 92px;
  }

  .ns-date-day {
    font-family: var(--font-display);
    font-size: 2.4rem;
    font-weight: 600;
    line-height: 1;
    color: var(--color-accent);
  }

  .ns-date-month {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gold);
    margin-top: 4px;
  }

  .ns-date-dow {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-top: 8px;
  }

  .ns-body {
    min-width: 0;
    text-align: start;
  }

  .ns-badge {
    display: inline-block;
    background: var(--color-accent);
    color: white;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 2px 10px;
    border-radius: 999px;
    margin-bottom: var(--space-sm);
  }

  .ns-title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    line-height: 1.1;
    margin-bottom: var(--space-sm);
    color: var(--color-text);
  }

  .ns-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: var(--space-md);
  }

  .ns-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .ns-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .ns-action {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border: 1px solid rgba(239, 230, 216, 0.15);
    background: rgba(255, 255, 255, 0.04);
    border-radius: var(--radius-md);
    color: var(--color-text);
    font: inherit;
    font-size: 0.85rem;
    text-decoration: none;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .ns-action:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
    background: rgba(242, 199, 92, 0.06);
  }

  .ns-action-primary {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }

  .ns-action-primary:hover {
    background: #c95d3d;
    border-color: #c95d3d;
    color: white;
  }

  @media (max-width: 640px) {
    .ns-card {
      grid-template-columns: 1fr;
      padding: var(--space-md);
      gap: var(--space-md);
    }

    .ns-date {
      flex-direction: row;
      gap: var(--space-sm);
      padding: var(--space-sm) var(--space-md);
      min-width: 0;
      justify-content: start;
    }

    .ns-date-day {
      font-size: 1.8rem;
    }

    .ns-date-dow {
      margin-top: 0;
      margin-inline-start: auto;
    }

    .ns-actions {
      gap: 6px;
    }

    .ns-action {
      padding: 8px 10px;
      font-size: 0.8rem;
    }
  }
</style>
