---
import Icon from './Icon.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  title: string;
  descriptionNl: string;
  descriptionEn: string;
  descriptionAra?: string;
  rating: string;
  contentWarnings?: string;
  date: string;
  time: string;
  language?: string;
  subtitles?: string;
  headphones?: string;
  previewUrl?: string;
  imageUrl?: string;
  isNext?: boolean;
  location?: string;
  preProgramStartMin?: number;
  preProgramNl?: string;
  preProgramEn?: string;
  preProgramAra?: string;
}

const { title, descriptionNl, descriptionEn, descriptionAra = '', rating, contentWarnings, date, time, language, subtitles, headphones, previewUrl, imageUrl, isNext, location, preProgramStartMin = 0, preProgramNl = '', preProgramEn = '', preProgramAra = '' } = Astro.props;

// Get age icon path
function getAgeIcon(age: string): string {
  const normalized = age.toLowerCase();
  return `/images/kijkwijzer/${normalized}.svg`;
}
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Convert language codes to full names
function getLanguageName(code: string | undefined): string {
  if (!code) return '';
  const normalized = code.toLowerCase().trim();

  // Language name mappings (displayed based on site language)
  const languageNames: Record<string, { nl: string; en: string; ara: string }> = {
    'en': { nl: 'Engels', en: 'English', ara: 'الإنجليزية' },
    'nl': { nl: 'Nederlands', en: 'Dutch', ara: 'الهولندية' },
    'de': { nl: 'Duits', en: 'German', ara: 'الألمانية' },
    'fr': { nl: 'Frans', en: 'French', ara: 'الفرنسية' },
    'es': { nl: 'Spaans', en: 'Spanish', ara: 'الإسبانية' },
    'it': { nl: 'Italiaans', en: 'Italian', ara: 'الإيطالية' },
    'pt': { nl: 'Portugees', en: 'Portuguese', ara: 'البرتغالية' },
    'ja': { nl: 'Japans', en: 'Japanese', ara: 'اليابانية' },
    'ko': { nl: 'Koreaans', en: 'Korean', ara: 'الكورية' },
    'zh': { nl: 'Chinees', en: 'Chinese', ara: 'الصينية' },
    'ru': { nl: 'Russisch', en: 'Russian', ara: 'الروسية' },
    'ar': { nl: 'Arabisch', en: 'Arabic', ara: 'العربية' },
    'hi': { nl: 'Hindi', en: 'Hindi', ara: 'الهندية' },
    'english': { nl: 'Engels', en: 'English', ara: 'الإنجليزية' },
    'dutch': { nl: 'Nederlands', en: 'Dutch', ara: 'الهولندية' },
    'german': { nl: 'Duits', en: 'German', ara: 'الألمانية' },
    'french': { nl: 'Frans', en: 'French', ara: 'الفرنسية' },
    'spanish': { nl: 'Spaans', en: 'Spanish', ara: 'الإسبانية' },
    'italian': { nl: 'Italiaans', en: 'Italian', ara: 'الإيطالية' },
    'portuguese': { nl: 'Portugees', en: 'Portuguese', ara: 'البرتغالية' },
    'japanese': { nl: 'Japans', en: 'Japanese', ara: 'اليابانية' },
    'korean': { nl: 'Koreaans', en: 'Korean', ara: 'الكورية' },
    'chinese': { nl: 'Chinees', en: 'Chinese', ara: 'الصينية' },
    'russian': { nl: 'Russisch', en: 'Russian', ara: 'الروسية' },
    'arabic': { nl: 'Arabisch', en: 'Arabic', ara: 'العربية' },
    'nederlands': { nl: 'Nederlands', en: 'Dutch', ara: 'الهولندية' },
    'engels': { nl: 'Engels', en: 'English', ara: 'الإنجليزية' },
    'duits': { nl: 'Duits', en: 'German', ara: 'الألمانية' },
    'frans': { nl: 'Frans', en: 'French', ara: 'الفرنسية' },
    'spaans': { nl: 'Spaans', en: 'Spanish', ara: 'الإسبانية' },
  };

  const mapping = languageNames[normalized];
  if (mapping) {
    return mapping[lang] || mapping.en;
  }

  // Return original if no mapping found (capitalize first letter)
  return code.charAt(0).toUpperCase() + code.slice(1);
}

// Get description based on current language (ARA falls back to EN if not provided)
const description = lang === 'nl'
  ? descriptionNl
  : lang === 'ara'
    ? (descriptionAra || descriptionEn)
    : descriptionEn;

// Extract YouTube video ID for thumbnail
function getYouTubeThumbnail(url: string | undefined): string {
  if (!url) return '/images/movie-placeholder.svg';
  const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:embed\/|v\/|watch\?v=|watch\?.+&v=))([^&?]+)/);
  if (match) {
    return `https://img.youtube.com/vi/${match[1]}/maxresdefault.jpg`;
  }
  return '/images/movie-placeholder.svg';
}

const thumbnail = imageUrl || getYouTubeThumbnail(previewUrl);

// Pre-program start time — driven by preProgramStartMin from schedule.csv
function earlier(showtime: string, minutesBefore: number): string {
  const [h, m] = showtime.split(':').map(Number);
  if (Number.isNaN(h) || Number.isNaN(m)) return '';
  const total = (((h * 60 + m - minutesBefore) % 1440) + 1440) % 1440;
  return `${String(Math.floor(total / 60)).padStart(2, '0')}:${String(total % 60).padStart(2, '0')}`;
}
const preProgramText = lang === 'nl'
  ? preProgramNl
  : lang === 'ara'
    ? (preProgramAra || preProgramEn)
    : preProgramEn;
const hasPreProgram = preProgramStartMin > 0 && preProgramText.length > 0;
const preProgramTime = hasPreProgram ? earlier(time, preProgramStartMin) : '';

// Format date for display
function formatDate(dateStr: string): string {
  try {
    const date = new Date(dateStr);
    const localeMap: Record<string, string> = { nl: 'nl-NL', en: 'en-US', ara: 'ar-SA' };
    return date.toLocaleDateString(localeMap[lang] || 'en-US', {
      weekday: 'long',
      day: 'numeric',
      month: 'long'
    });
  } catch {
    return dateStr;
  }
}
---

<article class:list={['movie-card', { 'is-next': isNext }]}>
  {isNext && (
    <div class="next-badge">
      {t('schedule.nextScreening')}
    </div>
  )}

  <div class="movie-image">
    <img src={thumbnail} alt={title} loading="lazy" />
    {previewUrl && (
      <a href={previewUrl} target="_blank" rel="noopener" class="play-button" aria-label={t('common.watchTrailer')}
         data-goatcounter-click={`trailer-${title.toLowerCase().replace(/\s+/g, '-')}`}
         data-goatcounter-title={`Trailer: ${title}`}>
        <svg width="48" height="48" viewBox="0 0 24 24" fill="currentColor">
          <path d="M8 5v14l11-7z"/>
        </svg>
      </a>
    )}
  </div>

  <div class="movie-content">
    <div class="movie-meta">
      <div class="meta-row meta-date">
        <img src={getAgeIcon(rating)} alt={`Kijkwijzer ${rating}`} class="kijkwijzer-icon" />
        <span class="movie-date">{formatDate(date)}</span>
      </div>
      {hasPreProgram && (
        <div class="meta-row meta-pre">
          <span aria-hidden="true">🪩</span>
          <span class="meta-label">{preProgramText}</span>
          <span class="meta-time">{preProgramTime}</span>
        </div>
      )}
      <div class="meta-row meta-film">
        <span class="meta-icon-wrap"><Icon name="film" size={14} /></span>
        <span>{t('gather.showtime')}</span>
        <span class="meta-time">{time}</span>
      </div>
    </div>

    <h3 class="movie-title">{title}</h3>
    <p class="movie-description">{description}</p>

    {(language || subtitles || headphones || location) && (
      <div class="movie-languages">
        {language && !['TBA', 'n/a', 'N/A', ''].includes(language) && (
          <span class="lang-tag" title={t('movie.spokenLanguage')}>
            <Icon name="languages" size={14} /> {t('movie.language')}: {getLanguageName(language)}
          </span>
        )}
        {subtitles && !['TBA', 'n/a', 'N/A', ''].includes(subtitles) && (
          <span class="lang-tag" title={t('movie.subtitles')}>
            <Icon name="message-circle" size={14} /> {t('movie.subtitles')}: {getLanguageName(subtitles)}
          </span>
        )}
        {headphones && !['TBA', 'n/a', 'N/A', ''].includes(headphones) && (
          <span class="lang-tag" title={t('movie.headphones')}>
            <Icon name="headphones" size={14} /> {headphones}
          </span>
        )}
        {location && (
          <span class="lang-tag location-tag" title={t('movie.location')}>
            <Icon name="map-pin" size={14} /> {location}
          </span>
        )}
      </div>
    )}
  </div>
</article>

<style>
  .movie-card {
    position: relative;
    background: var(--color-card);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-normal);
  }

  .movie-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .movie-card.is-next {
    border: 2px solid var(--color-accent);
  }

  .next-badge {
    position: absolute;
    top: var(--space-md);
    inset-inline-start: var(--space-md);
    z-index: 10;
    background: var(--color-accent);
    color: white;
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .movie-image {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .movie-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-normal);
  }

  .movie-card:hover .movie-image img {
    transform: scale(1.05);
  }

  .play-button {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.4);
    color: white;
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .movie-card:hover .play-button {
    opacity: 1;
  }

  .play-button svg {
    background: var(--color-accent);
    border-radius: 50%;
    padding: 12px;
    width: 64px;
    height: 64px;
    transition: transform var(--transition-fast);
  }

  .play-button:hover svg {
    transform: scale(1.1);
  }

  .movie-content {
    padding: var(--space-lg);
  }

  .movie-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: var(--space-md);
    font-size: 0.875rem;
  }

  .meta-row {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
  }

  .meta-date {
    align-items: center;
    color: var(--color-text-muted);
  }

  .meta-icon-wrap {
    display: inline-flex;
    align-items: center;
    padding-top: 2px;
  }

  .kijkwijzer-icon {
    width: 24px;
    height: 24px;
  }

  .meta-pre,
  .meta-film {
    color: var(--color-text-muted);
  }

  .meta-film {
    align-items: center;
  }

  .meta-pre .meta-label {
    flex: 1;
    min-width: 0;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .meta-time {
    margin-inline-start: auto;
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .movie-title {
    margin-bottom: var(--space-sm);
    font-size: 1.25rem;
  }

  .movie-description {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .movie-languages {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: var(--space-md);
  }

  .lang-tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .lang-tag.location-tag {
    background: var(--color-accent, #D76E4D);
    color: #ffffff;
    border-color: var(--color-accent, #D76E4D);
    font-weight: 600;
    width: 100%;
  }
</style>
