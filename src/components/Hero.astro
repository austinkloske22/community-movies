---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="hero">
  <div class="hero-bg">
    <img src="/images/outdoor-sunset.jpg" alt="" class="hero-image" />
  </div>
  <div class="container">
    <div class="hero-content">
      <h1 class="hero-title fade-in">
        <img src="/images/brand/text-logo-clear-background.png" alt={t('hero.title')} class="hero-logo" />
      </h1>
      <p class="hero-slogan fade-in">
        {t('hero.slogan')}
      </p>
      <p class="hero-subtitle fade-in">
        {t('hero.subtitle')}
      </p>
      <div class="hero-info fade-in">
        <a href={getLocalizedPath('/programma/haarlem', lang)} class="hero-badge hero-badge-link hero-badge-active">
          <span class="badge-icon">📍</span>
          <span>Haarlem</span>
          <span class="active-indicator">{t('hero.badgeActive')}</span>
        </a>
        <a href={getLocalizedPath('/programma/tiel', lang)} class="hero-badge hero-badge-link hero-badge-announced">
          <span class="badge-icon">📍</span>
          <span>Tiel</span>
          <span class="announced-indicator">{t('hero.badgeAnnounced')}</span>
        </a>
        <a href={getLocalizedPath('/programma/ijmuiden', lang)} class="hero-badge hero-badge-link hero-badge-announced">
          <span class="badge-icon">📍</span>
          <span>IJmuiden</span>
          <span class="announced-indicator">{t('hero.badgeAnnounced')}</span>
        </a>
        <div class="hero-badge">
          <span class="badge-icon">🏘️</span>
          <span>{t('hero.badgeYourNeighborhood')}</span>
        </div>
      </div>
      <div class="hero-ctas fade-in">
        <a href={getLocalizedPath('/programma', lang)} class="btn btn-primary hero-cta">
          {t('hero.cta')}
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href={getLocalizedPath('/voor-gemeenten', lang)} class="btn btn-secondary hero-cta-secondary">
          {t('hero.ctaMunicipalities')}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(26, 26, 46, 0.5) 0%, rgba(26, 26, 46, 0.7) 50%, var(--color-primary) 100%),
      radial-gradient(ellipse at 20% 50%, rgba(215, 110, 77, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 80%, rgba(242, 199, 92, 0.08) 0%, transparent 50%);
  }

  .hero-content {
    position: relative;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .hero-title {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0;
  }

  .hero-logo {
    width: clamp(300px, 50vw, 600px);
    height: auto;
    object-fit: contain;
    margin-bottom: clamp(-80px, -12vw, -40px);
  }

  .hero-slogan {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 500;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    line-height: 1.7;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-info {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .hero-badge {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    padding: var(--space-sm) var(--space-md);
    font-size: 0.9rem;
  }

  .badge-icon {
    font-size: 1.25rem;
  }

  .hero-badge-link {
    color: inherit;
    text-decoration: none;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .hero-badge-link:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .hero-badge-active {
    background: rgba(215, 110, 77, 0.1);
    border-color: rgba(215, 110, 77, 0.3);
  }

  .active-indicator {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-accent);
    color: white;
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    margin-inline-start: var(--space-xs);
  }

  .hero-badge-announced {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .announced-indicator {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: rgba(255, 255, 255, 0.15);
    color: var(--color-text-muted);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    margin-inline-start: var(--space-xs);
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
  }

  .hero-cta {
    font-size: 1.125rem;
    padding: var(--space-md) var(--space-xl);
  }

  .hero-cta-secondary {
    font-size: 1rem;
    padding: var(--space-md) var(--space-lg);
  }

  .fade-in {
    opacity: 0;
    animation: fadeIn 0.8s ease forwards;
  }

  .hero-title.fade-in {
    animation-delay: 0.1s;
  }

  .hero-slogan.fade-in {
    animation-delay: 0.15s;
  }

  .hero-subtitle.fade-in {
    animation-delay: 0.2s;
  }

  .hero-info.fade-in {
    animation-delay: 0.3s;
  }

  .hero-ctas.fade-in {
    animation-delay: 0.4s;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 85vh;
    }

    .hero-title {
      flex-direction: column;
      gap: var(--space-sm);
    }

    .hero-info {
      flex-direction: column;
      align-items: center;
    }

    .hero-ctas {
      flex-direction: column;
      align-items: center;
    }

    .hero-cta,
    .hero-cta-secondary {
      width: 100%;
      max-width: 300px;
    }
  }
</style>
