---
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
import type { Movie } from '../lib/sheets';
import Icon from './Icon.astro';
import heroImg from '../assets/outdoor-sunset.jpg';

interface Props {
  movie?: Movie | null;
}

const { movie = null } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const localeMap: Record<string, string> = { nl: 'nl-NL', en: 'en-GB', ara: 'ar-SA' };
const nextDate = movie
  ? new Date(movie.date).toLocaleDateString(localeMap[lang] || 'en-GB', { day: 'numeric', month: 'short' })
  : '';
---

<section class="hero">
  <div class="hero-bg">
    <Image
      src={heroImg}
      alt=""
      widths={[800, 1200, 1600, 2400]}
      sizes="100vw"
      formats={['avif', 'webp']}
      loading="eager"
      fetchpriority="high"
      class="hero-image"
    />
  </div>
  <div class="container">
    <div class="hero-content">
      <h1 class="hero-title fade-in">
        <img src="/images/brand/text-logo-clear-background.png" alt={t('hero.title')} class="hero-logo" />
      </h1>
      <p class="hero-slogan fade-in">
        {t('hero.slogan')}
      </p>
      <p class="hero-subtitle fade-in">
        {t('hero.subtitle')}
      </p>
      <div class="hero-info fade-in">
        <a href={getLocalizedPath('/programma/haarlem', lang)} class="hero-badge hero-badge-link hero-badge-active">
          <span class="badge-icon"><Icon name="map-pin" size={18} /></span>
          <span>Haarlem</span>
          <span class="active-indicator">{t('hero.badgeActive')}</span>
        </a>
        <a href={getLocalizedPath('/programma/tiel', lang)} class="hero-badge hero-badge-link hero-badge-announced">
          <span class="badge-icon"><Icon name="map-pin" size={18} /></span>
          <span>Tiel</span>
          <span class="announced-indicator">{t('hero.badgeAnnounced')}</span>
        </a>
        <a href={getLocalizedPath('/programma/ijmuiden', lang)} class="hero-badge hero-badge-link hero-badge-announced">
          <span class="badge-icon"><Icon name="map-pin" size={18} /></span>
          <span>IJmuiden</span>
          <span class="announced-indicator">{t('hero.badgeAnnounced')}</span>
        </a>
        <div class="hero-badge">
          <span class="badge-icon"><Icon name="home" size={18} /></span>
          <span>{t('hero.badgeYourNeighborhood')}</span>
        </div>
      </div>
      <div class="hero-ctas fade-in">
        <a href={getLocalizedPath('/programma', lang)} class="btn btn-primary hero-cta">
          {t('hero.cta')}
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href={getLocalizedPath('/voor-gemeenten', lang)} class="btn btn-secondary hero-cta-secondary">
          {t('hero.ctaMunicipalities')}
        </a>
      </div>
    </div>
  </div>
  {movie && (
    <a class="hero-next-strip" href="#next-screening">
      <span class="hero-next-label">{t('hero.nextLabel')}</span>
      <span class="hero-next-date">{nextDate}</span>
      <span class="hero-next-title">{movie.title}</span>
      <span class="hero-next-arrow" aria-hidden="true">→</span>
    </a>
  )}
</section>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(26, 26, 46, 0.5) 0%, rgba(26, 26, 46, 0.7) 50%, var(--color-primary) 100%),
      radial-gradient(ellipse at 20% 50%, rgba(215, 110, 77, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 80%, rgba(242, 199, 92, 0.08) 0%, transparent 50%);
  }

  .hero-content {
    position: relative;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .hero-title {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0;
  }

  .hero-logo {
    width: clamp(300px, 50vw, 600px);
    height: auto;
    object-fit: contain;
    margin-bottom: clamp(-80px, -12vw, -40px);
  }

  .hero-slogan {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 500;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    line-height: 1.7;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-info {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .hero-badge {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    padding: var(--space-sm) var(--space-md);
    font-size: 0.9rem;
  }

  .badge-icon {
    font-size: 1.25rem;
  }

  .hero-badge-link {
    color: inherit;
    text-decoration: none;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .hero-badge-link:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .hero-badge-active {
    background: rgba(215, 110, 77, 0.1);
    border-color: rgba(215, 110, 77, 0.3);
  }

  .active-indicator {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-accent);
    color: white;
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    margin-inline-start: var(--space-xs);
  }

  .hero-badge-announced {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .announced-indicator {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: rgba(255, 255, 255, 0.15);
    color: var(--color-text-muted);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    margin-inline-start: var(--space-xs);
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
  }

  .hero-cta {
    font-size: 1.125rem;
    padding: var(--space-md) var(--space-xl);
  }

  .hero-cta-secondary {
    font-size: 1rem;
    padding: var(--space-md) var(--space-lg);
  }

  .fade-in {
    opacity: 0;
    animation: fadeIn 0.8s ease forwards;
  }

  .hero-title.fade-in {
    animation-delay: 0.1s;
  }

  .hero-slogan.fade-in {
    animation-delay: 0.15s;
  }

  .hero-subtitle.fade-in {
    animation-delay: 0.2s;
  }

  .hero-info.fade-in {
    animation-delay: 0.3s;
  }

  .hero-ctas.fade-in {
    animation-delay: 0.4s;
  }

  /* Pinned next-screening sliver — mobile only, teases the block below */
  .hero-next-strip {
    display: none;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 65vh;
      padding-bottom: 56px;
    }

    .hero-title {
      flex-direction: column;
      gap: var(--space-sm);
    }

    .hero-info {
      flex-direction: column;
      align-items: center;
    }

    .hero-ctas {
      flex-direction: column;
      align-items: center;
    }

    .hero-cta,
    .hero-cta-secondary {
      width: 100%;
      max-width: 300px;
    }

    .hero-next-strip {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      height: 48px;
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      padding: 0 var(--space-md);
      background: rgba(0, 0, 0, 0.45);
      backdrop-filter: blur(6px);
      color: var(--color-text);
      text-decoration: none;
      font-size: 0.85rem;
      border-top: 1px solid rgba(255, 255, 255, 0.08);
      z-index: 3;
    }
    .hero-next-label {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-gold);
      font-weight: 600;
      flex-shrink: 0;
    }
    .hero-next-date {
      color: var(--color-accent);
      font-weight: 600;
      flex-shrink: 0;
    }
    .hero-next-title {
      color: var(--color-text);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      flex: 1;
    }
    .hero-next-arrow {
      color: var(--color-text-muted);
      flex-shrink: 0;
    }
  }
</style>
