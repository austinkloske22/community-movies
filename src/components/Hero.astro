---
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
import type { Movie } from '../lib/sheets';
import NextScreeningCard from './NextScreeningCard.astro';
import heroImg from '../assets/outdoor-sunset.jpg';

interface Props {
  movie?: Movie | null;
}

const { movie = null } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const siteUrl = Astro.site?.toString() ?? 'https://nelsonsfilm.nl';
const pageUrl = new URL(Astro.url.pathname, siteUrl).toString();
---

<section class="hero">
  <div class="hero-bg">
    <Image
      src={heroImg}
      alt=""
      widths={[800, 1200, 1600, 2400]}
      sizes="100vw"
      formats={['avif', 'webp']}
      loading="eager"
      fetchpriority="high"
      class="hero-image"
    />
  </div>
  <div class="container hero-container">
    <div class="hero-content">
      <h1 class="hero-title fade-in">
        <img src="/images/brand/text-logo-clear-background.png" alt={t('hero.title')} class="hero-logo" />
      </h1>
      <p class="hero-slogan fade-in">{t('hero.slogan')}</p>
      <p class="hero-subtitle fade-in">{t('hero.subtitle')}</p>
      <div class="hero-cta-row fade-in">
        <a href={getLocalizedPath('/programma', lang)} class="btn btn-primary hero-cta">
          {t('hero.cta')}
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>

    {movie && (
      <div class="hero-card fade-in">
        <NextScreeningCard movie={movie} lang={lang} pageUrl={pageUrl} />
      </div>
    )}
  </div>
</section>

<script>
  // Hero card actions delegate to the same handlers used on NextScreening.astro
  // — the ICS download wiring lives there, but the button copies sit on the hero
  // card too. Hook up the calendar button and the "RSVP" scroll-and-open.
  document.querySelectorAll('.ns-action.action-calendar').forEach((btn) => {
    btn.addEventListener('click', () => {
      const text = btn.dataset.ics;
      const filename = btn.dataset.icsFilename || 'nelsonsfilm.ics';
      if (!text) return;
      const blob = new Blob([text], { type: 'text/calendar;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      a.remove();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    });
  });

  // When the hero-card "Let us know you're coming" anchor is clicked, also
  // open the collapsed RSVP panel below (so the user doesn't have to click
  // the toggle again).
  document.querySelectorAll('.ns-rsvp-scroll').forEach((a) => {
    a.addEventListener('click', () => {
      const panel = document.getElementById('rsvp-panel');
      const toggle = document.querySelector('.action-rsvp-toggle');
      if (panel && panel.hasAttribute('hidden')) {
        panel.removeAttribute('hidden');
        if (toggle) toggle.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(26, 26, 46, 0.45) 0%, rgba(26, 26, 46, 0.6) 50%, var(--color-primary) 100%),
      radial-gradient(ellipse at 20% 50%, rgba(215, 110, 77, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 80%, rgba(242, 199, 92, 0.08) 0%, transparent 50%);
  }

  .hero-container {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xl);
  }

  .hero-content {
    text-align: center;
    max-width: 760px;
    margin: 0 auto;
  }

  .hero-title {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0;
  }

  .hero-logo {
    width: clamp(260px, 42vw, 500px);
    height: auto;
    object-fit: contain;
    /* No negative margin — the logo now breathes into the slogan.
     * Prior clamp(-60px, -9vw, -30px) clipped the wordmark at some
     * viewport sizes and read as broken. */
    margin-bottom: var(--space-xs);
  }

  .hero-slogan {
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 3.2vw, 2rem);
    font-weight: 500;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    line-height: 1.7;
    max-width: 600px;
    margin-inline: auto;
  }

  .hero-cta-row {
    display: flex;
    justify-content: center;
  }

  .hero-cta {
    font-size: 1.05rem;
    padding: var(--space-md) var(--space-xl);
  }

  .hero-card {
    max-width: 640px;
    margin: 0 auto;
    width: 100%;
  }

  .fade-in {
    opacity: 0;
    animation: fadeIn 0.7s ease forwards;
  }

  .hero-title.fade-in { animation-delay: 0.1s; }
  .hero-slogan.fade-in { animation-delay: 0.2s; }
  .hero-subtitle.fade-in { animation-delay: 0.3s; }
  .hero-cta-row.fade-in { animation-delay: 0.4s; }
  .hero-card.fade-in { animation-delay: 0.5s; }

  @media (min-width: 960px) {
    .hero-container {
      grid-template-columns: 1.05fr 0.95fr;
      gap: var(--space-xl);
      align-items: center;
    }
    .hero-content {
      text-align: start;
      margin: 0;
    }
    .hero-title {
      justify-content: flex-start;
    }
    .hero-cta-row {
      justify-content: flex-start;
    }
    .hero-subtitle {
      margin-inline: 0;
    }
    .hero-card {
      margin: 0;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: var(--space-lg) 0;
    }

    .hero-title {
      flex-direction: column;
      gap: var(--space-sm);
    }

    .hero-cta-row {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-cta {
      width: 100%;
      min-height: 48px;
      justify-content: center;
    }
  }
</style>
