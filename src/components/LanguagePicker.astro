---
import { languages } from '../i18n/ui';
import { getLangFromUrl, getRouteFromUrl } from '../i18n/utils';

const currentLang = getLangFromUrl(Astro.url);
const route = getRouteFromUrl(Astro.url);

// Simple language switching - paths stay the same, only prefix changes
function buildHref(targetLang: string): string {
  const path = route || '';
  if (targetLang === 'nl') {
    return path || '/';
  }
  return `/${targetLang}${path}`;
}
---

<div class="language-picker">
  {Object.entries(languages).map(([lang, label]) => (
    <a
      href={buildHref(lang)}
      class:list={['lang-btn', { active: currentLang === lang }]}
    >
      {lang.toUpperCase()}
    </a>
  ))}
</div>

<style>
  .language-picker {
    display: flex;
    gap: var(--space-xs);
    background: rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-md);
    padding: 2px;
  }

  .lang-btn {
    padding: var(--space-xs) var(--space-sm);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }

  .lang-btn:hover {
    color: var(--color-text);
  }

  .lang-btn.active {
    background: var(--color-accent);
    color: white;
  }
</style>
