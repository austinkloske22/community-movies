---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
import type { Movie } from '../lib/sheets';
import Icon from './Icon.astro';
import RsvpForm from './RsvpForm.astro';
import { buildIcs, slugifyForFilename } from '../lib/ics.ts';

interface Props {
  movie: Movie | null;
}

const { movie } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Pre-build the ICS blob + filename at build time so the client-side
// calendar button is a tiny no-dep download.
const siteUrl = Astro.site?.toString() ?? 'https://nelsonsfilm.nl';
const pageUrl = new URL(Astro.url.pathname, siteUrl).toString();
const icsText = movie
  ? buildIcs({
      title: `Nelsons Film — ${movie.title}`,
      date: movie.date,
      time: movie.time,
      location: movie.location || 'Nelson Mandelapark, Haarlem',
      description: lang === 'nl' ? movie.descriptionNl : lang === 'ara' ? (movie.descriptionAra || movie.descriptionEn) : movie.descriptionEn,
      url: pageUrl,
    })
  : '';
const icsFilename = movie ? `nelsonsfilm-${slugifyForFilename(movie.title)}-${movie.date.replace(/-/g, '')}.ics` : '';

// WhatsApp share — prebuild the href; button is just an <a target="_blank">.
const waDateText = movie
  ? new Date(movie.date).toLocaleDateString(lang === 'nl' ? 'nl-NL' : lang === 'ara' ? 'ar-SA' : 'en-GB', { day: 'numeric', month: 'long' })
  : '';
const waMessage = movie
  ? `${t('share.whatsappPrefix')} ${movie.title} — ${waDateText} · ${pageUrl}`
  : '';
const whatsappHref = movie ? `https://wa.me/?text=${encodeURIComponent(waMessage)}` : '#';

// Get age icon path
function getAgeIcon(age: string): string {
  const normalized = age.toLowerCase();
  return `/images/kijkwijzer/${normalized}.svg`;
}

// Format date for display
function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  const localeMap: Record<string, string> = { nl: 'nl-NL', en: 'en-US', ara: 'ar-SA' };
  return date.toLocaleDateString(localeMap[lang] || 'en-US', {
    weekday: 'long',
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
}

// Extract YouTube video ID
function getYouTubeId(url: string): string | null {
  const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:embed\/|v\/|watch\?v=|watch\?.+&v=))([^&?]+)/);
  return match ? match[1] : null;
}

const youtubeId = movie?.previewUrl ? getYouTubeId(movie.previewUrl) : null;

// Pre-program / community hour — driven by movie.preProgramStartMin from schedule.csv
function earlier(time: string, minutesBefore: number): string {
  const [h, m] = time.split(':').map(Number);
  if (Number.isNaN(h) || Number.isNaN(m)) return '';
  const total = (((h * 60 + m - minutesBefore) % 1440) + 1440) % 1440;
  return `${String(Math.floor(total / 60)).padStart(2, '0')}:${String(total % 60).padStart(2, '0')}`;
}
const preProgramText = movie
  ? (lang === 'nl'
      ? movie.preProgramNl
      : lang === 'ara'
        ? (movie.preProgramAra || movie.preProgramEn)
        : movie.preProgramEn)
  : '';
const hasPreProgram = !!movie && movie.preProgramStartMin > 0 && preProgramText.length > 0;
const gatherTime = hasPreProgram && movie ? earlier(movie.time, movie.preProgramStartMin) : '';

// Get description based on current language
const description = movie
  ? (lang === 'nl'
      ? movie.descriptionNl
      : lang === 'ara'
        ? (movie.descriptionAra || movie.descriptionEn)
        : movie.descriptionEn)
  : '';
---

{movie ? (
  <section class="next-screening section" id="next-screening">
    <div class="container">
      <div class="screening-header">
        <span class="screening-badge">{t('schedule.nextScreening')} — {movie.location || 'Haarlem'}</span>
        <h2 class="screening-title">{movie.title}</h2>
      </div>

      <div class="screening-content">
        <div class="screening-video">
          {youtubeId ? (
            <div class="video-wrapper">
              <iframe
                src={`https://www.youtube.com/embed/${youtubeId}`}
                title={`${movie.title} trailer`}
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
          ) : (
            <div class="video-placeholder">
              <img src="/images/brand/icon-logo-clear-background.png" alt="Nelsons Film" class="placeholder-icon" />
              <span>{t('movie.trailerComingSoon')}</span>
            </div>
          )}
        </div>

        <div class="screening-details">
          <div class="detail-card">
            <span class="detail-icon"><Icon name="calendar" size={22} /></span>
            <div class="detail-content">
              <span class="detail-label">{t('schedule.date')}</span>
              <span class="detail-value">{formatDate(movie.date)}</span>
            </div>
          </div>

          <div class="detail-card">
            <span class="detail-icon"><Icon name="clock" size={22} /></span>
            <div class="detail-content">
              <span class="detail-label">{t('schedule.time')}</span>
              {hasPreProgram && (
                <span class="detail-timeline"><strong>{gatherTime}</strong> {preProgramText}</span>
              )}
              <span class="detail-timeline"><strong>{movie.time}</strong> — {t('gather.showtime')}</span>
            </div>
          </div>

          <div class="detail-card">
            <span class="detail-icon"><Icon name="map-pin" size={22} /></span>
            <div class="detail-content">
              <span class="detail-label">{t('location.title')}</span>
              <span class="detail-value">{movie.location || 'Nelson Mandelapark, Haarlem'}</span>
            </div>
          </div>

          <div class="kijkwijzer-badge">
            <img src={getAgeIcon(movie.rating)} alt={`Kijkwijzer ${movie.rating}`} class="kijkwijzer-icon" />
            <div class="kijkwijzer-text">
              <span class="kijkwijzer-label">{t('movie.kijkwijzer')}</span>
              <span class="kijkwijzer-explain" title={t('movie.kijkwijzerExplain')}>{t('movie.kijkwijzerExplain')}</span>
            </div>
          </div>

          {(movie.language || movie.subtitles || movie.headphones) && (
            <div class="language-info">
              {movie.language && !['TBA', 'n/a', 'N/A', ''].includes(movie.language) && (
                <div class="lang-item">
                  <span class="lang-icon"><Icon name="languages" size={16} /></span>
                  <span class="lang-label">{t('movie.language')}:</span>
                  <span class="lang-value">{movie.language}</span>
                </div>
              )}
              {movie.subtitles && !['TBA', 'n/a', 'N/A', ''].includes(movie.subtitles) && (
                <div class="lang-item">
                  <span class="lang-icon"><Icon name="message-circle" size={16} /></span>
                  <span class="lang-label">{t('movie.subtitles')}:</span>
                  <span class="lang-value">{movie.subtitles}</span>
                </div>
              )}
              {movie.headphones && !['TBA', 'n/a', 'N/A', ''].includes(movie.headphones) && (
                <div class="lang-item">
                  <span class="lang-icon"><Icon name="headphones" size={16} /></span>
                  <span class="lang-label">{t('movie.headphones')}:</span>
                  <span class="lang-value">{movie.headphones}</span>
                </div>
              )}
            </div>
          )}

          <p class="screening-description">{description}</p>

          <div class="screening-actions">
            <button type="button" class="action-btn action-calendar"
                    data-ics={icsText}
                    data-ics-filename={icsFilename}>
              <Icon name="calendar" size={16} />
              {t('share.addToCalendar')}
            </button>
            <a href={whatsappHref} target="_blank" rel="noopener" class="action-btn">
              <Icon name="share-2" size={16} />
              {t('share.whatsapp')}
            </a>
            <button type="button" class="action-btn action-rsvp-toggle" aria-expanded="false" aria-controls="rsvp-panel">
              <Icon name="users" size={16} />
              {t('rsvp.expandCta')}
            </button>
          </div>

          <a href={getLocalizedPath('/programma', lang)} class="btn btn-secondary view-schedule">
            {t('movie.viewFullSchedule')}
          </a>
        </div>
      </div>

      <div id="rsvp-panel" class="rsvp-panel" hidden>
        <RsvpForm movie={movie} lang={lang} />
      </div>
    </div>
  </section>
  <script>
    // --- Calendar download ---
    document.querySelectorAll('.action-calendar').forEach((btn) => {
      btn.addEventListener('click', () => {
        const text = btn.dataset.ics;
        const filename = btn.dataset.icsFilename || 'nelsonsfilm.ics';
        if (!text) return;
        const blob = new Blob([text], { type: 'text/calendar;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        a.remove();
        setTimeout(() => URL.revokeObjectURL(url), 1000);
      });
    });

    // --- RSVP disclosure ---
    document.querySelectorAll('.action-rsvp-toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        const panel = document.getElementById('rsvp-panel');
        if (!panel) return;
        const open = panel.hasAttribute('hidden') ? false : true;
        if (open) {
          panel.setAttribute('hidden', '');
          btn.setAttribute('aria-expanded', 'false');
        } else {
          panel.removeAttribute('hidden');
          btn.setAttribute('aria-expanded', 'true');
          const input = panel.querySelector('input[type="email"]');
          if (input) input.focus();
          panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      });
    });
  </script>
) : (
  <section class="next-screening section" id="next-screening">
    <div class="container text-center">
      <p class="text-muted">{t('schedule.noUpcoming')}</p>
    </div>
  </section>
)}

<style>
  .next-screening {
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-primary) 100%);
  }

  .screening-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .screening-badge {
    display: inline-block;
    background: var(--color-accent);
    color: white;
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-lg);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
  }

  .screening-title {
    font-size: clamp(2rem, 5vw, 3rem);
  }

  .screening-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
  }

  .video-wrapper iframe {
    position: absolute;
    top: 0;
    inset-inline-start: 0;
    width: 100%;
    height: 100%;
  }

  .video-placeholder {
    aspect-ratio: 16 / 9;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    background: var(--color-card);
    border-radius: var(--radius-lg);
    color: var(--color-text-muted);
  }

  .placeholder-icon {
    height: 64px;
    width: 64px;
    object-fit: contain;
    border-radius: 8px;
  }

  .screening-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .detail-card {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-md);
    padding: var(--space-md);
  }

  .detail-icon {
    font-size: 1.5rem;
  }

  .detail-content {
    display: flex;
    flex-direction: column;
  }

  .detail-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .detail-value {
    font-weight: 600;
  }

  .kijkwijzer-badge {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-md);
    padding: var(--space-md);
  }

  .kijkwijzer-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .kijkwijzer-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-gold);
    font-weight: 500;
  }

  .kijkwijzer-explain {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .kijkwijzer-icon {
    width: 64px;
    height: 64px;
    flex-shrink: 0;
  }

  .language-info {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .lang-item {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
  }

  .lang-icon {
    font-size: 1rem;
  }

  .lang-label {
    color: var(--color-text-muted);
  }

  .lang-value {
    font-weight: 500;
  }

  .detail-timeline {
    display: block;
    margin-top: 4px;
    font-size: 0.95rem;
    line-height: 1.45;
    color: var(--color-text-muted);
  }

  .detail-timeline strong {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
    margin-inline-end: 4px;
  }

  .screening-description {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .screening-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-md);
    color: var(--color-text);
    text-decoration: none;
    cursor: pointer;
    font: inherit;
    font-size: 0.9rem;
    transition: all var(--transition-fast);
  }

  .action-btn:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
    background: rgba(242, 199, 92, 0.05);
  }

  .action-rsvp-toggle {
    background: rgba(215, 110, 77, 0.1);
    border-color: rgba(215, 110, 77, 0.35);
    color: var(--color-text);
  }

  .action-rsvp-toggle:hover {
    background: rgba(215, 110, 77, 0.18);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .view-schedule {
    margin-top: var(--space-md);
  }

  .rsvp-panel {
    margin-top: var(--space-xl);
  }

  @media (max-width: 900px) {
    .screening-content {
      grid-template-columns: 1fr;
    }
  }
</style>
