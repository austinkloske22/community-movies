---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const features = [
  { icon: '🎧', key: 'home.feature1' },
  { icon: '🌍', key: 'home.feature2' },
  { icon: '🤝', key: 'home.feature3' },
  { icon: '🎬', key: 'home.feature4' },
  { icon: '⭐', key: 'home.feature5' },
];

const moreThanItems = [
  t('home.moreThanItem1'),
  t('home.moreThanItem2'),
  t('home.moreThanItem3'),
  t('home.moreThanItem4'),
];
---

<section class="features-section section">
  <div class="container">
    <!-- For Everyone Section — 60/40 split -->
    <div class="split-section split-60-40">
      <div class="split-left">
        <h2 class="section-title">{t('home.forEveryoneTitle')}</h2>
        <p class="section-text">{t('home.forEveryoneText')}</p>
        <p class="section-subtext">{t('home.accessibilityText')}</p>
      </div>
      <div class="split-right">
        <div class="features-grid">
          {features.map((feature) => (
            <div class="feature-item">
              <span class="feature-icon">{feature.icon}</span>
              <span class="feature-text">{t(feature.key)}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- More Than + Proven Concept — side by side -->
    <div class="split-section split-50-50">
      <div class="content-block alt-bg">
        <h2 class="section-title">{t('home.moreThanTitle')}</h2>
        <p class="section-text">{t('home.moreThanText')}</p>

        <ul class="experience-list">
          {moreThanItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>

        <p class="community-note">{t('home.communityProject')}</p>
      </div>

      <div class="content-block">
        <h2 class="section-title">{t('home.provenTitle')}</h2>
        <p class="section-text">{t('home.provenText')}</p>
        <a href={getLocalizedPath('/programma', lang)} class="btn btn-primary">
          {t('home.viewProgram')}
        </a>
      </div>
    </div>

    <!-- Municipality CTA — full width -->
    <div class="content-block highlight-block">
      <h2 class="section-title">{t('home.municipalityTitle')}</h2>
      <p class="section-text">{t('home.municipalityText')}</p>
      <a href={getLocalizedPath('/voor-gemeenten', lang)} class="btn btn-primary">
        {t('home.municipalityCta')}
      </a>
    </div>
  </div>
</section>

<style>
  .features-section {
    background: var(--color-bg);
  }

  /* Split layouts */
  .split-section {
    display: grid;
    gap: var(--space-lg);
    max-width: 1100px;
    margin: 0 auto var(--space-xl);
    align-items: stretch;
  }

  .split-60-40 {
    grid-template-columns: 3fr 2fr;
  }

  .split-50-50 {
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
  }

  .split-left,
  .split-right {
    padding: var(--space-xl);
    background: var(--color-card);
    border-radius: var(--radius-lg);
  }

  /* Content blocks (used in split and standalone) */
  .content-block {
    padding: var(--space-xl);
    background: var(--color-card);
    border-radius: var(--radius-lg);
  }

  .content-block.alt-bg {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .content-block.highlight-block {
    max-width: 800px;
    margin: 0 auto;
    background: linear-gradient(135deg, rgba(233, 69, 96, 0.1), rgba(244, 162, 97, 0.05));
    border: 1px solid rgba(233, 69, 96, 0.2);
    text-align: center;
  }

  .section-title {
    margin-bottom: var(--space-md);
    color: var(--color-text);
  }

  .section-text {
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }

  .section-subtext {
    color: var(--color-text-muted);
    font-style: italic;
    margin-top: var(--space-lg);
    padding-top: var(--space-lg);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .features-grid {
    display: grid;
    gap: var(--space-md);
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md);
    background: rgba(255, 255, 255, 0.02);
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .feature-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .feature-text {
    color: var(--color-text);
    font-size: 0.95rem;
  }

  .experience-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-lg);
  }

  .experience-list li {
    position: relative;
    padding-left: var(--space-lg);
    margin-bottom: var(--space-sm);
    color: var(--color-text-muted);
  }

  .experience-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: bold;
  }

  .community-note {
    font-weight: 600;
    color: var(--color-text);
    font-style: italic;
    text-align: center;
    padding-top: var(--space-md);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .highlight-block .section-title {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .split-section {
      grid-template-columns: 1fr;
    }

    .split-left,
    .split-right,
    .content-block {
      padding: var(--space-lg);
    }
  }
</style>
