---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
import Icon from './Icon.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const features = [
  { icon: 'headphones', key: 'home.feature1' },
  { icon: 'globe', key: 'home.feature2' },
  { icon: 'handshake', key: 'home.feature3' },
  { icon: 'film', key: 'home.feature4' },
  { icon: 'star', key: 'home.feature5' },
] as const;

const moreThanItems = [
  { title: t('home.moreThanItem1'), detail: t('home.moreThanDetail1') },
  { title: t('home.moreThanItem2'), detail: t('home.moreThanDetail2') },
  { title: t('home.moreThanItem3'), detail: t('home.moreThanDetail3') },
  { title: t('home.moreThanItem4'), detail: t('home.moreThanDetail4') },
  { title: t('home.moreThanItem5'), detail: t('home.moreThanDetail5') },
  { title: t('home.moreThanItem6'), detail: t('home.moreThanDetail6') },
];
---

<section class="features-section section">
  <div class="container">
    <!-- For Everyone Section — 60/40 split -->
    <div class="split-section split-60-40">
      <div class="split-left">
        <h2 class="section-title">{t('home.forEveryoneTitle')}</h2>
        <p class="section-text">{t('home.forEveryoneText')}</p>
        <p class="section-subtext">{t('home.accessibilityText')}</p>
      </div>
      <div class="split-right">
        <div class="features-grid">
          {features.map((feature) => (
            <div class="feature-item">
              <span class="feature-icon"><Icon name={feature.icon} size={22} /></span>
              <span class="feature-text">{t(feature.key)}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- More Than a Film Night -->
    <div class="content-block alt-bg" style="max-width: 800px; margin: 0 auto var(--space-xl);">
      <h2 class="section-title">{t('home.moreThanTitle')}</h2>
      <p class="section-text">{t('home.moreThanText')}</p>

      <div class="mt-faq-list">
        {moreThanItems.map((item) => (
          <details class="mt-faq-item">
            <summary>
              <span>{item.title}</span>
              <Icon name="chevron-down" size={20} class="mt-faq-chev" />
            </summary>
            <p>{item.detail}</p>
          </details>
        ))}
      </div>

      <p class="community-note">{t('home.communityProject')}</p>
    </div>

    <!-- Municipality CTA — minimal bleed, not a card -->
    <div class="muni-cta">
      <h2 class="muni-cta-title">{t('home.municipalityTitle')}</h2>
      <p class="muni-cta-text">{t('home.municipalityText')}</p>
      <a href={getLocalizedPath('/voor-gemeenten', lang)} class="btn btn-primary">
        {t('home.municipalityCta')}
      </a>
    </div>
  </div>
</section>

<style>
  .features-section {
    background: var(--color-bg);
  }

  /* Split layouts */
  .split-section {
    display: grid;
    gap: var(--space-lg);
    max-width: 1100px;
    margin: 0 auto var(--space-xl);
    align-items: stretch;
  }

  .split-60-40 {
    grid-template-columns: 3fr 2fr;
  }

  .split-50-50 {
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
  }

  .split-left,
  .split-right {
    padding: var(--space-xl);
    background: var(--color-card);
    border-radius: var(--radius-lg);
  }

  /* Content blocks (used in split and standalone) */
  .content-block {
    padding: var(--space-xl);
    background: var(--color-card);
    border-radius: var(--radius-lg);
  }

  .content-block.alt-bg {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .content-block.highlight-block {
    max-width: 800px;
    margin: 0 auto;
    background: linear-gradient(135deg, rgba(215, 110, 77, 0.1), rgba(242, 199, 92, 0.05));
    border: 1px solid rgba(215, 110, 77, 0.2);
    text-align: center;
  }

  .muni-cta {
    max-width: 720px;
    margin: var(--space-xl) auto 0;
    padding: var(--space-xl) var(--space-md);
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .muni-cta-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: var(--space-sm);
    color: var(--color-accent);
  }

  .muni-cta-text {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
    max-width: 560px;
    margin-inline: auto;
  }

  .section-title {
    margin-bottom: var(--space-md);
    color: var(--color-text);
  }

  .section-text {
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }

  .section-subtext {
    color: var(--color-text-muted);
    font-style: italic;
    margin-top: var(--space-lg);
    padding-top: var(--space-lg);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .features-grid {
    display: grid;
    gap: var(--space-md);
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md);
    background: rgba(255, 255, 255, 0.02);
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .feature-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .feature-text {
    color: var(--color-text);
    font-size: 0.95rem;
  }

  .mt-faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin: 0 0 var(--space-lg);
  }

  .mt-faq-item {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-md);
    padding: 0;
    transition: background var(--transition-fast), border-color var(--transition-fast);
  }

  .mt-faq-item:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(215, 110, 77, 0.25);
  }

  .mt-faq-item[open] {
    background: rgba(215, 110, 77, 0.06);
    border-color: rgba(215, 110, 77, 0.3);
  }

  .mt-faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    cursor: pointer;
    list-style: none;
    font-weight: 500;
    color: var(--color-text);
  }

  .mt-faq-item summary::-webkit-details-marker {
    display: none;
  }

  .mt-faq-chev {
    color: var(--color-accent);
    flex-shrink: 0;
    transition: transform var(--transition-fast);
  }

  .mt-faq-item[open] .mt-faq-chev {
    transform: rotate(180deg);
  }

  .mt-faq-item p {
    margin: 0;
    padding: 0 var(--space-lg) var(--space-md);
    color: var(--color-text-muted);
    line-height: 1.7;
    font-size: 0.95rem;
  }

  .community-note {
    font-weight: 600;
    color: var(--color-text);
    font-style: italic;
    text-align: center;
    padding-top: var(--space-md);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .highlight-block .section-title {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .split-section {
      grid-template-columns: 1fr;
    }

    .split-left,
    .split-right,
    .content-block {
      padding: var(--space-lg);
    }
  }
</style>
