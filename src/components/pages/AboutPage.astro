---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DonateButton from '../DonateButton.astro';
import Icon from '../Icon.astro';
import SponsorStrip from '../SponsorStrip.astro';
import Numbers from '../Numbers.astro';
import Testimonial from '../Testimonial.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const values = [
  t('about.value1'),
  t('about.value2'),
  t('about.value3'),
  t('about.value4'),
  t('about.value5'),
];
---

<BaseLayout title={t('nav.about')} description={t('about.intro')}>
  <section class="about-page section">
    <div class="container">
      <header class="page-header">
        <h1>{t('about.title')}</h1>
      </header>

      <div class="about-content">
        <div class="split-section split-45-55">
          <!-- Mission Section -->
          <div class="content-section mission">
            <h2>{t('about.missionTitle')}</h2>
            <p class="mission-text">{t('about.missionText')}</p>
            <p class="mission-subtext">{t('about.missionSubtext')}</p>
          </div>

          <!-- History Section -->
          <div class="content-section">
            <h2>{t('about.historyTitle')}</h2>
            <p>{t('about.historyText')}</p>
            <p>{t('about.historyText2')}</p>
            <p>{t('about.historyText3')}</p>
          </div>
        </div>

        <!-- Photo essay -->
        <div class="photo-essay">
          <h2 class="photo-essay-title">{t('about.ourEvents')}</h2>

          <!-- (a) 21:9 full-bleed hero -->
          <figure class="pe-hero">
            <img src="/images/outdoor-sunset.jpg" alt={t('about.altSunset')} loading="lazy" />
            <figcaption>{t('about.altSunset')}</figcaption>
          </figure>

          <!-- (b) 2-up asymmetric -->
          <div class="pe-duo">
            <figure class="pe-duo-lg">
              <img src="/images/park-screening.jpg" alt={t('about.altPark')} loading="lazy" />
              <figcaption>{t('about.altPark')}</figcaption>
            </figure>
            <figure class="pe-duo-sm">
              <img src="/images/audience-indoor.jpg" alt={t('about.altCozy')} loading="lazy" />
              <figcaption>{t('about.altCozy')}</figcaption>
            </figure>
          </div>

          <!-- (c) centered portrait -->
          <figure class="pe-portrait">
            <img src="/images/family-screening.jpg" alt={t('about.altFamily')} loading="lazy" />
            <figcaption>{t('about.altFamily')}</figcaption>
          </figure>

          <!-- (d) landscape strip -->
          <div class="pe-strip">
            <figure>
              <img src="/images/event-party.jpg" alt={t('about.altFestive')} loading="lazy" />
              <figcaption>{t('about.altFestive')}</figcaption>
            </figure>
            <figure>
              <img src="/images/venue-screening.jpg" alt={t('about.altWinter')} loading="lazy" />
              <figcaption>{t('about.altWinter')}</figcaption>
            </figure>
          </div>
        </div>

        <div class="split-section split-55-45">
          <!-- Values Section -->
          <div class="content-section values">
            <h2>{t('about.valuesTitle')}</h2>
            <ul class="values-list">
              {values.map((value) => (
                <li>{value}</li>
              ))}
            </ul>
            <p class="values-note">{t('about.valuesSubtext')}</p>
          </div>

          <!-- Foundation Section -->
          <div class="content-section foundation">
            <h2>{t('about.foundationTitle')}</h2>
            <p>{t('about.foundationText')}</p>
            <a href={getLocalizedPath('/voor-gemeenten', lang)} class="link-arrow">
              {t('about.partnerCta')} →
            </a>
          </div>
        </div>

        <!-- Donate Section -->
        <div class="donate-section">
          <p>{t('about.donateText')}</p>
          <DonateButton lang={lang} variant="primary" />
        </div>

        <!-- Numbers strip -->
        <Numbers />

        <!-- Testimonials -->
        <div class="tl-section">
          <h2 class="tl-section-title">{t('testimonials.title')}</h2>
          <Testimonial variant="row" limit={2} />
        </div>

        <!-- Sponsors / partners -->
        <SponsorStrip variant="full" />

        <!-- Press/Links Section -->
        <div class="press-section">
          <h2>{t('about.inTheNews')}</h2>
          <div class="press-links">
            <a href="https://www.023magazine.nl/cultuur-uitgaan/3149-succesvolle-bewonersinitiatieven" target="_blank" rel="noopener" class="press-link">
              <span class="press-icon"><Icon name="newspaper" size={18} /></span>
              <span>{t('about.newsItem023')}</span>
            </a>
            <a href="https://www.haarlemlink.nl/nieuws/pitch-nelson-film" target="_blank" rel="noopener" class="press-link">
              <span class="press-icon"><Icon name="newspaper" size={18} /></span>
              <span>{t('about.newsItemHaarlemlink')}</span>
            </a>
            <a href="https://www.haarlemmerdagblad.nl/uitgaan/nelsons-film-brengt-buurt-samen-met-gratis-pop-up-bioscoop-in-haarlem-noord" target="_blank" rel="noopener" class="press-link">
              <span class="press-icon"><Icon name="newspaper" size={18} /></span>
              <span>{t('about.newsItemDagblad')}</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .tl-section {
    max-width: 1100px;
    margin: var(--space-xl) auto;
    padding: 0 var(--space-md);
  }
  .tl-section-title {
    text-align: center;
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: var(--space-lg);
  }

  .about-page {
    min-height: 80vh;
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .about-content {
    max-width: 1100px;
    margin: 0 auto;
  }

  .content-section {
    background: var(--color-card);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    margin-bottom: var(--space-xl);
  }

  .content-section h2 {
    margin-bottom: var(--space-md);
  }

  .content-section p {
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: var(--space-md);
  }

  .content-section p:last-of-type {
    margin-bottom: 0;
  }

  .mission {
    background: linear-gradient(135deg, rgba(215, 110, 77, 0.08), rgba(242, 199, 92, 0.04));
    border: 1px solid rgba(215, 110, 77, 0.15);
  }

  .mission-text {
    font-size: 1.1rem;
    color: var(--color-text);
  }

  .mission-subtext {
    font-style: italic;
    padding-top: var(--space-md);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin-top: var(--space-md);
  }

  .values-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-lg);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-sm);
  }

  .values-list li {
    padding: var(--space-sm) var(--space-md);
    background: rgba(255, 255, 255, 0.03);
    border-radius: var(--radius-md);
    color: var(--color-text);
    text-align: center;
  }

  .values-note {
    font-style: italic;
    text-align: center;
    padding-top: var(--space-md);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .link-arrow {
    display: inline-block;
    color: var(--color-accent);
    font-weight: 500;
    margin-top: var(--space-md);
  }

  .link-arrow:hover {
    color: var(--color-accent-light);
  }

  /* ---- Photo essay (B13) ---- */
  .photo-essay {
    margin: var(--space-xl) 0;
  }

  .photo-essay-title {
    font-size: 0.82rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .photo-essay figure {
    margin: 0;
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
  }

  .photo-essay img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-normal);
  }

  .photo-essay figure:hover img {
    transform: scale(1.02);
  }

  .photo-essay figcaption {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-text);
    opacity: 0.9;
    font-size: 0.95rem;
    margin-top: var(--space-sm);
    padding: 0 var(--space-xs);
  }

  /* (a) 21:9 hero */
  .pe-hero {
    aspect-ratio: 21 / 9;
    margin-bottom: var(--space-xl);
  }

  .pe-hero figcaption {
    position: absolute;
    bottom: var(--space-md);
    inset-inline-start: var(--space-lg);
    inset-inline-end: var(--space-lg);
    color: var(--color-text);
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.6);
    font-size: 1.05rem;
    margin: 0;
  }

  .pe-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(180deg, transparent 50%, rgba(27, 47, 74, 0.7) 100%);
  }

  /* (b) 2-up asymmetric */
  .pe-duo {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .pe-duo-lg {
    aspect-ratio: 4 / 3;
  }

  .pe-duo-sm {
    aspect-ratio: 3 / 4;
    align-self: end;
  }

  /* (c) centered portrait */
  .pe-portrait {
    max-width: 560px;
    margin: 0 auto var(--space-xl);
    aspect-ratio: 4 / 5;
  }

  /* (d) landscape strip */
  .pe-strip {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .pe-strip figure {
    aspect-ratio: 16 / 10;
  }

  .donate-section {
    background: linear-gradient(135deg, rgba(215, 110, 77, 0.1), rgba(242, 199, 92, 0.05));
    border: 1px solid rgba(215, 110, 77, 0.2);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .donate-section p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    line-height: 1.7;
  }

  .press-section {
    margin-bottom: var(--space-xl);
  }

  .press-section h2 {
    margin-bottom: var(--space-md);
  }

  .press-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .press-link {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md);
    background: var(--color-card);
    border-radius: var(--radius-md);
    color: var(--color-text);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .press-link:hover {
    background: var(--color-card-hover);
    transform: translateX(4px);
  }

  .press-icon {
    font-size: 1.5rem;
  }

  .split-section {
    display: grid;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
    align-items: stretch;
  }

  .split-45-55 {
    grid-template-columns: 45fr 55fr;
  }

  .split-55-45 {
    grid-template-columns: 55fr 45fr;
  }

  .split-section > .content-section {
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .pe-hero { aspect-ratio: 16 / 11; }
    .pe-duo,
    .pe-strip {
      grid-template-columns: 1fr;
    }
    .pe-duo-lg,
    .pe-duo-sm { aspect-ratio: 16 / 10; }

    .content-section {
      padding: var(--space-lg);
    }

    .split-section {
      grid-template-columns: 1fr;
    }

    .values-list {
      grid-template-columns: 1fr;
    }
  }
</style>
