---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../Icon.astro';
import Numbers from '../Numbers.astro';
import Testimonial from '../Testimonial.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const deliverables = [
  t('partner.whatYouGet1'),
  t('partner.whatYouGet2'),
  t('partner.whatYouGet3'),
  t('partner.whatYouGet4'),
  t('partner.whatYouGet5'),
  t('partner.whatYouGet6'),
  t('partner.whatYouGet7'),
];

const steps = [
  { title: t('partner.howStep1'), body: t('partner.howStep1Body') },
  { title: t('partner.howStep2'), body: t('partner.howStep2Body') },
  { title: t('partner.howStep3'), body: t('partner.howStep3Body') },
];

const faqs = [
  { q: t('partner.faqQ1'), a: t('partner.faqA1') },
  { q: t('partner.faqQ2'), a: t('partner.faqA2') },
  { q: t('partner.faqQ3'), a: t('partner.faqA3') },
  { q: t('partner.faqQ4'), a: t('partner.faqA4') },
];

const samenwerkingHref = `/samenwerking/${lang === 'en' ? '?lang=en' : ''}`;
---

<BaseLayout title={t('nav.municipalities')} description={t('partner.heroLede')}>
  <!-- Hero -->
  <section class="p-hero">
    <div class="container p-hero-inner">
      <p class="p-kicker">{t('partner.kicker')}</p>
      <h1 class="p-hero-title">{t('partner.heroTitle')}</h1>
      <p class="p-hero-lede">{t('partner.heroLede')}</p>
      <div class="p-cta-row">
        <a href={samenwerkingHref} class="btn btn-primary p-cta-primary">
          {t('partner.primaryCta')}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href={getLocalizedPath('/contact', lang)} class="p-cta-secondary">
          {t('partner.secondaryCta')} →
        </a>
      </div>
    </div>
  </section>

  <!-- Numbers -->
  <Numbers />

  <!-- Testimonial (single, municipal) -->
  <section class="p-proof container">
    <Testimonial variant="single" kind="municipal" />
  </section>

  <!-- What you get -->
  <section class="p-deliverables container">
    <div class="p-deliverables-head">
      <h2>{t('partner.whatYouGetTitle')}</h2>
      <p>{t('partner.whatYouGetIntro')}</p>
    </div>
    <ul class="p-deliverables-list">
      {deliverables.map((item) => (
        <li>
          <Icon name="check" size={18} />
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- How it works -->
  <section class="p-how container">
    <h2>{t('partner.howTitle')}</h2>
    <ol class="p-how-list">
      {steps.map((step, i) => (
        <li class="p-how-item">
          <div class="p-how-num">{i + 1}</div>
          <div class="p-how-body">
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- FAQ -->
  <section class="p-faq container">
    <h2>{t('partner.faqTitle')}</h2>
    <div class="p-faq-list">
      {faqs.map((faq) => (
        <details class="p-faq-item">
          <summary>
            <span>{faq.q}</span>
            <Icon name="chevron-down" size={20} class="p-faq-chev" />
          </summary>
          <p>{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- End CTA -->
  <section class="p-end container">
    <h2>{t('partner.endCtaTitle')}</h2>
    <p>{t('partner.endCtaBody')}</p>
    <a href={samenwerkingHref} class="btn btn-primary p-cta-primary">
      {t('partner.primaryCta')}
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
    <p class="p-call-prompt">
      {t('partner.callPrompt')}
      <a href="tel:+31657576047" class="p-call-link">
        <Icon name="phone" size={16} /> +31 6 57576047
      </a>
    </p>
  </section>
</BaseLayout>

<style>
  /* ---- Hero ---- */
  .p-hero {
    padding: var(--space-xl) 0 var(--space-lg);
    background:
      radial-gradient(ellipse at 10% -20%, rgba(215, 110, 77, 0.18), transparent 60%),
      radial-gradient(ellipse at 90% 120%, rgba(242, 199, 92, 0.08), transparent 60%),
      var(--color-bg);
  }

  .p-hero-inner {
    max-width: 860px;
    text-align: start;
  }

  .p-kicker {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-gold);
    padding: 4px 12px;
    border: 1px solid rgba(242, 199, 92, 0.3);
    border-radius: 999px;
    margin-bottom: var(--space-lg);
  }

  .p-hero-title {
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    line-height: 1.08;
    margin-bottom: var(--space-md);
    letter-spacing: -0.01em;
    max-width: 18ch;
  }

  .p-hero-lede {
    font-size: clamp(1.05rem, 1.8vw, 1.2rem);
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 58ch;
    margin-bottom: var(--space-lg);
  }

  .p-cta-row {
    display: flex;
    gap: var(--space-md);
    align-items: center;
    flex-wrap: wrap;
  }

  .p-cta-primary {
    font-size: 1.05rem;
    padding: var(--space-md) var(--space-lg);
  }

  .p-cta-secondary {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color var(--transition-fast);
  }

  .p-cta-secondary:hover {
    color: var(--color-gold);
  }

  /* ---- Proof ---- */
  .p-proof {
    padding: var(--space-xl) var(--space-md);
  }

  /* ---- Deliverables ---- */
  .p-deliverables {
    max-width: 1000px;
    padding: var(--space-xl) var(--space-md);
  }

  .p-deliverables-head {
    margin-bottom: var(--space-lg);
    max-width: 640px;
  }

  .p-deliverables-head h2 {
    margin-bottom: var(--space-sm);
  }

  .p-deliverables-head p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .p-deliverables-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-md);
  }

  .p-deliverables-list li {
    display: flex;
    align-items: start;
    gap: var(--space-sm);
    padding: var(--space-md);
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-md);
    color: var(--color-text);
  }

  .p-deliverables-list :global(svg) {
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 3px;
  }

  /* ---- How it works ---- */
  .p-how {
    max-width: 1000px;
    padding: var(--space-xl) var(--space-md);
  }

  .p-how h2 {
    margin-bottom: var(--space-lg);
  }

  .p-how-list {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: steps;
    display: grid;
    gap: var(--space-lg);
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .p-how-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-lg);
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
  }

  .p-how-num {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
  }

  .p-how-body h3 {
    font-size: 1.1rem;
    margin-bottom: 6px;
  }

  .p-how-body p {
    color: var(--color-text-muted);
    line-height: 1.65;
    font-size: 0.95rem;
  }

  /* ---- FAQ ---- */
  .p-faq {
    max-width: 860px;
    padding: var(--space-xl) var(--space-md);
  }

  .p-faq h2 {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .p-faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .p-faq-item {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-md);
    padding: 0;
    transition: background var(--transition-fast), border-color var(--transition-fast);
  }

  .p-faq-item:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(215, 110, 77, 0.25);
  }

  .p-faq-item[open] {
    background: rgba(215, 110, 77, 0.06);
    border-color: rgba(215, 110, 77, 0.3);
  }

  .p-faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    cursor: pointer;
    list-style: none;
    font-weight: 500;
    color: var(--color-text);
  }

  .p-faq-item summary::-webkit-details-marker {
    display: none;
  }

  .p-faq-chev {
    color: var(--color-accent);
    flex-shrink: 0;
    transition: transform var(--transition-fast);
  }

  .p-faq-item[open] .p-faq-chev {
    transform: rotate(180deg);
  }

  .p-faq-item p {
    margin: 0;
    padding: 0 var(--space-lg) var(--space-md);
    color: var(--color-text-muted);
    line-height: 1.7;
    font-size: 0.95rem;
  }

  /* ---- End CTA ---- */
  .p-end {
    max-width: 720px;
    padding: var(--space-xl) var(--space-md) calc(var(--space-xl) * 1.5);
    text-align: center;
  }

  .p-end h2 {
    margin-bottom: var(--space-sm);
  }

  .p-end p {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .p-call-prompt {
    margin-top: var(--space-md);
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .p-call-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-inline-start: 4px;
    color: var(--color-accent);
    font-weight: 500;
  }

  .p-call-link:hover {
    color: var(--color-gold);
  }
</style>
