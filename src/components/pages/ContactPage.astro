---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DonateButton from '../DonateButton.astro';
import Icon from '../Icon.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/utils';
import { DONATIONS_ENABLED } from '../../lib/features';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const emailAddress = 'Nelsons.film.Haarlem@gmail.com';

const secondaryLinks = [
  { icon: 'phone', label: t('contact.callUs'), sub: '+31 6 57576047', href: 'tel:+31657576047', external: false },
  { icon: 'instagram', label: t('contact.instagram'), sub: '@nelsonsfilm', href: 'https://instagram.com/nelsonsfilm', external: true },
  ...(DONATIONS_ENABLED
    ? [{ icon: 'heart', label: t('contact.donate'), sub: null, href: null, external: false, donate: true }]
    : []),
  { icon: 'handshake', label: t('contact.sponsor'), sub: null, href: getLocalizedPath('/in-jouw-buurt', lang), external: false },
  { icon: 'landmark', label: t('contact.municipalitiesLink'), sub: null, href: getLocalizedPath('/in-jouw-buurt', lang), external: false },
] as const;
---

<BaseLayout title={t('nav.contact')} description={t('contact.text')}>
  <section class="contact-page section">
    <div class="container">
      <header class="page-header">
        <p class="page-kicker">{t('contact.subtitle')}</p>
        <h1>{t('contact.title')}</h1>
        <p class="page-text">{t('contact.text')}</p>
      </header>

      <!-- Primary action: email -->
      <div class="primary-contact">
        <div class="primary-icon" aria-hidden="true"><Icon name="mail" size={32} /></div>
        <div class="primary-body">
          <h2>{t('contact.emailUs')}</h2>
          <div class="primary-email-row">
            <a href={`mailto:${emailAddress}`} class="primary-email">{emailAddress}</a>
            <button type="button" class="copy-btn"
                    data-copy={emailAddress}
                    data-copied={t('contact.copied')}
                    aria-label={t('contact.copy')}>
              <Icon name="copy" size={16} />
              <span class="copy-label">{t('contact.copy')}</span>
            </button>
          </div>
          <p class="reply-time">{t('contact.replyTime')}</p>
        </div>
      </div>

      <!-- Secondary options -->
      <ul class="secondary-list" aria-label={t('contact.followUs')}>
        {secondaryLinks.map((item) => (
          <li class="secondary-item">
            {item.donate ? (
              <div class="secondary-inner">
                <Icon name={item.icon} size={20} />
                <div class="secondary-content">
                  <span class="secondary-label">{item.label}</span>
                </div>
                <DonateButton lang={lang} variant="secondary" />
              </div>
            ) : (
              <a href={item.href!} class="secondary-inner secondary-link"
                 target={item.external ? '_blank' : undefined}
                 rel={item.external ? 'noopener' : undefined}>
                <Icon name={item.icon} size={20} />
                <div class="secondary-content">
                  <span class="secondary-label">{item.label}</span>
                  {item.sub && <span class="secondary-sub">{item.sub}</span>}
                </div>
                <span class="secondary-arrow" aria-hidden="true">→</span>
              </a>
            )}
          </li>
        ))}
      </ul>

    </div>
  </section>
</BaseLayout>

<script>
  // Copy-to-clipboard for the email address, with a transient "Copied" state.
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    const value = btn.dataset.copy;
    if (!value) return;
    const labelEl = btn.querySelector('.copy-label');
    const original = labelEl && labelEl.textContent ? labelEl.textContent : '';
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(value);
        if (labelEl) {
          // Fall back to the shared i18n 'copied' label via data-attribute.
          labelEl.textContent = btn.dataset.copied || 'Copied';
          setTimeout(() => { labelEl.textContent = original; }, 1500);
        }
      } catch (e) {
        // clipboard API blocked — no-op, user can still select the link.
      }
    });
  });
</script>

<style>
  .contact-page {
    min-height: 80vh;
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--space-xl);
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  .page-kicker {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.75rem;
    color: var(--color-gold);
    margin-bottom: var(--space-sm);
  }

  .page-text {
    color: var(--color-text-muted);
    font-size: 1.0625rem;
    margin-top: var(--space-md);
    line-height: 1.7;
  }

  .primary-contact {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-lg);
    align-items: start;
    max-width: 720px;
    margin: 0 auto var(--space-xl);
    padding: var(--space-xl);
    background: linear-gradient(135deg, rgba(215, 110, 77, 0.12), rgba(242, 199, 92, 0.04));
    border: 1px solid rgba(215, 110, 77, 0.25);
    border-radius: var(--radius-lg);
  }

  .primary-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .primary-body h2 {
    font-size: 1.4rem;
    margin-bottom: var(--space-sm);
  }

  .primary-email-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .primary-email {
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--color-text);
    word-break: break-word;
  }

  .primary-email:hover {
    color: var(--color-accent-light);
  }

  .copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: transparent;
    border: 1px solid rgba(239, 230, 216, 0.18);
    color: var(--color-text-muted);
    padding: 6px 12px;
    border-radius: 999px;
    font-family: inherit;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .copy-btn:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  .reply-time {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-top: var(--space-sm);
    line-height: 1.6;
  }

  /* Secondary compact list */
  .secondary-list {
    list-style: none;
    padding: 0;
    margin: 0 auto var(--space-xl);
    max-width: 720px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .secondary-item {
    background: var(--color-bg);
  }

  .secondary-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    color: var(--color-text);
    text-decoration: none;
    transition: background var(--transition-fast);
  }

  .secondary-link:hover {
    background: rgba(255, 255, 255, 0.04);
  }

  .secondary-content {
    display: flex;
    flex-direction: column;
  }

  .secondary-label {
    font-weight: 500;
  }

  .secondary-sub {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin-top: 2px;
  }

  .secondary-arrow {
    color: var(--color-text-muted);
    transition: transform var(--transition-fast), color var(--transition-fast);
  }

  .secondary-link:hover .secondary-arrow {
    color: var(--color-accent);
    transform: translateX(3px);
  }

  @media (max-width: 640px) {
    .primary-contact {
      grid-template-columns: 1fr;
      gap: var(--space-md);
      padding: var(--space-lg);
    }
    .primary-icon {
      margin: 0 auto;
    }
  }
</style>
