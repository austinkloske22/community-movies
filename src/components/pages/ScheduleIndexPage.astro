---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../Icon.astro';
import { getHaarlemMovies, getTielMovies, getIJmuidenMovies, getAnnouncedUpcoming } from '../../lib/sheets';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// "Announced" filters out TBA placeholder rows — matches the per-location pages.
const haarlemAnnounced = getAnnouncedUpcoming(getHaarlemMovies());
const tielAnnounced = getAnnouncedUpcoming(getTielMovies());
const ijmuidenAnnounced = getAnnouncedUpcoming(getIJmuidenMovies());

interface Loc {
  city: string;
  href: string;
  count: number;
  active: boolean;
}

const locations: Loc[] = [
  { city: t('schedule.locationHaarlem'),  href: '/programma/haarlem',  count: haarlemAnnounced.length,  active: haarlemAnnounced.length > 0 },
  { city: t('schedule.locationTiel'),     href: '/programma/tiel',     count: tielAnnounced.length,     active: tielAnnounced.length > 0 },
  { city: t('schedule.locationIJmuiden'), href: '/programma/ijmuiden', count: ijmuidenAnnounced.length, active: ijmuidenAnnounced.length > 0 },
];
---

<BaseLayout title={t('schedule.title')} description="Bekijk het programma van Nelsons Film - gratis openluchtbioscoop op meerdere locaties">
  <section class="schedule-page section">
    <div class="container">
      <header class="page-header">
        <h1>{t('schedule.title')}</h1>
        <p class="page-subtitle">{t('schedule.chooseLocation')}</p>
        <p class="page-info">{t('schedule.selectionInfo')}</p>
        <p class="page-free">{t('schedule.freeInfo')}</p>
      </header>

      <div class="locations-grid">
        {locations.map((loc) => (
          <a href={getLocalizedPath(loc.href, lang)}
             class:list={['location-tile', !loc.active && 'location-tile-announced']}>
            <span class="tile-icon" aria-hidden="true">
              <Icon name="map-pin" size={26} />
            </span>
            <div class="tile-content">
              <div class="tile-heading">
                <span class="tile-city">{loc.city}</span>
                <span class:list={['tile-badge', !loc.active && 'tile-badge-announced']}>
                  {loc.active ? t('hero.badgeActive') : t('hero.badgeAnnounced')}
                </span>
              </div>
              <span class="tile-count">
                {loc.active
                  ? `${loc.count} ${t('schedule.activeScreenings')}`
                  : t('schedule.datesToBeAnnounced')}
              </span>
            </div>
            <span class="tile-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>

      <!-- Coming Soon Section -->
      <div class="coming-soon-section">
        <div class="coming-soon-content">
          <div class="coming-soon-icon"><Icon name="globe" size={42} /></div>
          <h2>{t('schedule.expandingTitle')}</h2>
          <p>{t('schedule.expandingText')}</p>
          <a href={getLocalizedPath('/voor-gemeenten', lang)} class="btn btn-primary">
            {t('schedule.expandingCta')}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .schedule-page {
    min-height: 80vh;
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .page-subtitle {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    margin-top: var(--space-sm);
  }

  .page-info {
    color: var(--color-text-muted);
    font-size: 1rem;
    margin-top: var(--space-md);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .page-free {
    color: var(--color-accent);
    font-size: 0.95rem;
    font-weight: 500;
    margin-top: var(--space-sm);
  }

  .locations-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-md);
    max-width: 900px;
    margin: 0 auto var(--space-xl);
  }

  .location-tile {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg);
    background: linear-gradient(135deg, rgba(215, 110, 77, 0.08), rgba(242, 199, 92, 0.03));
    border: 1px solid rgba(215, 110, 77, 0.25);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text);
    transition: all var(--transition-normal);
  }

  .location-tile:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 26px rgba(0, 0, 0, 0.3);
    border-color: var(--color-accent);
  }

  .tile-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(215, 110, 77, 0.15);
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .tile-content {
    display: flex;
    flex-direction: column;
    min-width: 0;
    gap: 4px;
  }

  .tile-heading {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .tile-city {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 500;
    line-height: 1.2;
    color: var(--color-text);
  }

  .tile-count {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .tile-badge {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--color-accent);
    color: white;
    padding: 4px 10px;
    border-radius: 999px;
    flex-shrink: 0;
  }

  .tile-badge-announced {
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-text-muted);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .location-tile-announced {
    background: rgba(255, 255, 255, 0.02);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .location-tile-announced .tile-icon {
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-text-muted);
  }

  .tile-arrow {
    font-size: 1.3rem;
    color: var(--color-text-muted);
    transition: transform var(--transition-fast);
    flex-shrink: 0;
  }

  .location-tile:hover .tile-arrow {
    transform: translateX(4px);
    color: var(--color-accent);
  }


  /* Coming Soon Section */
  .coming-soon-section {
    margin-top: var(--space-xl);
    padding: var(--space-xl);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0.05));
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .coming-soon-content {
    max-width: 600px;
    margin: 0 auto;
  }

  .coming-soon-icon {
    font-size: 3rem;
    margin-bottom: var(--space-md);
  }

  .coming-soon-section h2 {
    margin-bottom: var(--space-md);
    color: var(--color-text);
  }

  .coming-soon-section p {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  @media (max-width: 768px) {
    .locations-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
