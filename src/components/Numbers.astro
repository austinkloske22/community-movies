---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { numbers } from '../data/numbers';
import { STATS_ENABLED } from '../lib/features';

interface Props {
  /** Title shown above the stats. Omit for a bare strip. */
  title?: string;
  class?: string;
}

const { title, class: extraClass = '' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const formatter = new Intl.NumberFormat(lang === 'nl' ? 'nl-NL' : lang === 'ara' ? 'ar-SA' : 'en-GB');

const stats = [
  { value: `${t('numbers.sinceWord')} ${numbers.sinceYear}`, label: t('numbers.since') },
  { value: `${formatter.format(numbers.screenings)}+`, label: t('numbers.screenings') },
  { value: `${formatter.format(numbers.neighbours)}+`, label: t('numbers.neighbours') },
  { value: formatter.format(numbers.municipalities), label: t('numbers.municipalities') },
];
---

{STATS_ENABLED && (
<section class:list={['numbers', extraClass]}>
  {title && <h2 class="numbers-title">{title}</h2>}
  <dl class="numbers-list">
    {stats.map((stat) => (
      <div class="numbers-item">
        <dt class="numbers-value">{stat.value}</dt>
        <dd class="numbers-label">{stat.label}</dd>
      </div>
    ))}
  </dl>
</section>
)}

<style>
  .numbers {
    max-width: 1100px;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md);
    text-align: center;
  }

  .numbers-title {
    font-size: 0.82rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .numbers-list {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
    margin: 0;
    padding: 0;
  }

  .numbers-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
  }

  .numbers-value {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 500;
    line-height: 1;
    color: var(--color-accent);
    letter-spacing: -0.01em;
  }

  .numbers-label {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
  }

  @media (max-width: 720px) {
    .numbers-list {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
    }
  }
</style>
