---
import { getSettings } from '../lib/settings';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  lang: 'nl' | 'en';
  variant?: 'primary' | 'secondary';
  class?: string;
}

const { lang, variant = 'primary', class: className } = Astro.props;
const t = useTranslations(lang);
const buttonText = t('common.donateNow');
const settings = getSettings();

// Use Tikkie URL if configured, otherwise fallback to email
const href = settings.tikkie_url || 'mailto:Nelsons.film.Haarlem@gmail.com?subject=Donatie';
const isExternal = settings.tikkie_url ? true : false;
---

<a
  href={href}
  class:list={['btn', `btn-${variant}`, className]}
  target={isExternal ? '_blank' : undefined}
  rel={isExternal ? 'noopener' : undefined}
  data-goatcounter-click="donate-click"
  data-goatcounter-title={`Donate (${lang})`}
>
  {buttonText}
</a>
