---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MovieCard from '../../components/MovieCard.astro';
import { getTielMovies, getUpcomingMovies, getNextMovie } from '../../lib/sheets';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const movies = getTielMovies();
const upcomingMovies = getUpcomingMovies(movies);
const nextMovie = getNextMovie(movies);
---

<BaseLayout title={`${t('schedule.title')} — ${t('schedule.locationTiel')}`} description="Bekijk het programma van Nelsons Film in Tiel">
  <section class="schedule-page section">
    <div class="container">
      <div class="back-link">
        <a href={getLocalizedPath('/programma', lang)}>← {t('schedule.locations')}</a>
      </div>

      <header class="page-header">
        <h1>{t('schedule.title')} — {t('schedule.locationTiel')}</h1>
        {upcomingMovies.length > 0 && (
          <a href="/programma/tiel.ics" class="calendar-btn"
             data-goatcounter-click="calendar-tiel"
             data-goatcounter-title="Calendar download (nl)">
            📅 {t('schedule.addToCalendar')}
          </a>
        )}
        <p class="page-subtitle">{t('schedule.datesToBeAnnounced')}</p>
        <p class="page-info">{t('schedule.selectionInfo')}</p>
        <p class="page-free">{t('schedule.freeInfo')}</p>
      </header>

      {upcomingMovies.length > 0 ? (
        <div class="movies-grid grid grid-2">
          {upcomingMovies.map((movie) => (
            <MovieCard
              title={movie.title}
              descriptionNl={movie.descriptionNl}
              descriptionEn={movie.descriptionEn}
              rating={movie.rating}
              contentWarnings={movie.contentWarnings}
              date={movie.date}
              time={movie.time}
              language={movie.language}
              subtitles={movie.subtitles}
              headphones={movie.headphones}
              previewUrl={movie.previewUrl}
              location={movie.location}
              isNext={nextMovie?.date === movie.date}
            />
          ))}
        </div>
      ) : (
        <div class="no-movies">
          <p class="text-muted text-center">{t('schedule.noUpcoming')}</p>
        </div>
      )}

      <div class="schedule-info">
        <div class="info-card">
          <h3>🎧 {t('schedule.multilingualTitle')}</h3>
          <p>{t('schedule.multilingualText')}</p>
        </div>

        <div class="info-card">
          <h3>🪑 {t('schedule.whatToBringTitle')}</h3>
          <p>{t('schedule.whatToBringText')}</p>
        </div>

        <div class="info-card location-card">
          <h3>📍 {t('location.title')}</h3>
          <p>{t('schedule.locationTiel')}</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .schedule-page {
    min-height: 80vh;
  }

  .back-link {
    margin-bottom: var(--space-md);
  }

  .back-link a {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    transition: color var(--transition-fast);
  }

  .back-link a:hover {
    color: var(--color-accent);
  }

  .location-header {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-lg);
  }

  .location-badge {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    background: var(--color-card);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .location-badge.active {
    background: linear-gradient(135deg, rgba(233, 69, 96, 0.1), rgba(244, 162, 97, 0.05));
    border-color: rgba(233, 69, 96, 0.3);
  }

  .badge-icon {
    font-size: 1.5rem;
  }

  .badge-content {
    display: flex;
    flex-direction: column;
  }

  .badge-city {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-text);
  }

  .status-indicator {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-accent);
    color: white;
    padding: 4px 10px;
    border-radius: var(--radius-sm);
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .page-subtitle {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    margin-top: var(--space-sm);
  }

  .page-info {
    color: var(--color-text-muted);
    font-size: 1rem;
    margin-top: var(--space-md);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .page-free {
    color: var(--color-accent);
    font-size: 0.95rem;
    font-weight: 500;
    margin-top: var(--space-sm);
  }

  .calendar-btn {
    display: inline-block;
    margin-top: var(--space-md);
    padding: var(--space-md) var(--space-xl);
    background: rgba(233, 69, 96, 0.1);
    border: 1px solid rgba(233, 69, 96, 0.3);
    border-radius: var(--radius-md);
    color: var(--color-accent);
    font-size: 1.1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .calendar-btn:hover {
    background: rgba(233, 69, 96, 0.2);
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .movies-grid {
    margin-bottom: var(--space-xl);
  }

  .no-movies {
    padding: var(--space-xl);
    background: var(--color-card);
    border-radius: var(--radius-lg);
  }

  .schedule-info {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-lg);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-xl);
  }

  .info-card {
    background: var(--color-card);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
  }

  .info-card h3 {
    margin-bottom: var(--space-sm);
  }

  .info-card p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .location-card .map-link {
    display: inline-block;
    margin-top: var(--space-sm);
    color: var(--color-accent);
    font-weight: 500;
  }

  .location-card .map-link:hover {
    color: var(--color-accent-light);
  }

  @media (max-width: 768px) {
    .location-badge {
      flex-wrap: wrap;
      justify-content: center;
      text-align: center;
    }

    .badge-content {
      align-items: center;
    }
  }
</style>
