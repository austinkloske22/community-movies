---
import BaseLayout from '../layouts/BaseLayout.astro';
import DonateButton from '../components/DonateButton.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const values = [
  t('about.value1'),
  t('about.value2'),
  t('about.value3'),
  t('about.value4'),
  t('about.value5'),
];
---

<BaseLayout title={t('nav.about')} description={t('about.intro')}>
  <section class="about-page section">
    <div class="container">
      <header class="page-header">
        <h1>{t('about.title')}</h1>
      </header>

      <div class="about-content">
        <div class="split-section split-45-55">
          <!-- Mission Section -->
          <div class="content-section mission">
            <h2>{t('about.missionTitle')}</h2>
            <p class="mission-text">{t('about.missionText')}</p>
            <p class="mission-subtext">{t('about.missionSubtext')}</p>
          </div>

          <!-- History Section -->
          <div class="content-section">
            <h2>{t('about.historyTitle')}</h2>
            <p>{t('about.historyText')}</p>
            <p>{t('about.historyText2')}</p>
            <p>{t('about.historyText3')}</p>
          </div>
        </div>

        <!-- Photo Gallery -->
        <div class="photo-gallery">
          <h2>{t('about.ourEvents')}</h2>
          <div class="gallery-grid">
            <div class="gallery-item featured">
              <img src="/images/outdoor-sunset.jpg" alt={t('about.altSunset')} loading="lazy" />
            </div>
            <div class="gallery-item">
              <img src="/images/park-screening.jpg" alt={t('about.altPark')} loading="lazy" />
            </div>
            <div class="gallery-item">
              <img src="/images/family-screening.jpg" alt={t('about.altFamily')} loading="lazy" />
            </div>
            <div class="gallery-item">
              <img src="/images/audience-indoor.jpg" alt={t('about.altCozy')} loading="lazy" />
            </div>
            <div class="gallery-item">
              <img src="/images/venue-screening.jpg" alt={t('about.altWinter')} loading="lazy" />
            </div>
            <div class="gallery-item">
              <img src="/images/event-party.jpg" alt={t('about.altFestive')} loading="lazy" />
            </div>
          </div>
        </div>

        <div class="split-section split-55-45">
          <!-- Values Section -->
          <div class="content-section values">
            <h2>{t('about.valuesTitle')}</h2>
            <ul class="values-list">
              {values.map((value) => (
                <li>{value}</li>
              ))}
            </ul>
            <p class="values-note">{t('about.valuesSubtext')}</p>
          </div>

          <!-- Foundation Section -->
          <div class="content-section foundation">
            <h2>{t('about.foundationTitle')}</h2>
            <p>{t('about.foundationText')}</p>
            <a href={getLocalizedPath('/voor-gemeenten', lang)} class="link-arrow">
              {t('about.partnerCta')} →
            </a>
          </div>
        </div>

        <!-- Donate Section -->
        <div class="donate-section">
          <p>{t('about.donateText')}</p>
          <DonateButton lang={lang} variant="primary" />
        </div>

        <!-- Sponsors Section -->
        <div class="sponsors">
          <h2>{t('footer.sponsors')}</h2>
          <p class="text-muted">
            {t('about.madePossibleBy')}
          </p>
          <div class="sponsor-list">
            <a href="https://buurtamsterdam.nl" target="_blank" rel="noopener" class="sponsor">BUURT / Fjörd</a>
            <a href="https://cronje.nl" target="_blank" rel="noopener" class="sponsor">Cronjé</a>
            <a href="https://desnuffelmug.nl" target="_blank" rel="noopener" class="sponsor">De Snuffelmug</a>
            <a href="https://www.coa.nl" target="_blank" rel="noopener" class="sponsor">COA</a>
            <a href="https://www.haarlem.nl" target="_blank" rel="noopener" class="sponsor">Gemeente Haarlem</a>
            <a href="https://hbphoorne.nl" target="_blank" rel="noopener" class="sponsor">HBP Hoorne</a>
            <a href="https://duizend1.nl" target="_blank" rel="noopener" class="sponsor">Duizend1</a>
          </div>
        </div>

        <!-- Press/Links Section -->
        <div class="press-section">
          <h2>{t('about.inTheNews')}</h2>
          <div class="press-links">
            <a href="https://www.023magazine.nl/cultuur-uitgaan/3149-succesvolle-bewonersinitiatieven" target="_blank" rel="noopener" class="press-link">
              <span class="press-icon">📰</span>
              <span>{t('about.newsItem023')}</span>
            </a>
            <a href="https://www.haarlemlink.nl/nieuws/pitch-nelson-film" target="_blank" rel="noopener" class="press-link">
              <span class="press-icon">📰</span>
              <span>{t('about.newsItemHaarlemlink')}</span>
            </a>
            <a href="https://www.haarlemmerdagblad.nl/uitgaan/nelsons-film-brengt-buurt-samen-met-gratis-pop-up-bioscoop-in-haarlem-noord" target="_blank" rel="noopener" class="press-link">
              <span class="press-icon">📰</span>
              <span>{t('about.newsItemDagblad')}</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-page {
    min-height: 80vh;
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .about-content {
    max-width: 1100px;
    margin: 0 auto;
  }

  .content-section {
    background: var(--color-card);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    margin-bottom: var(--space-xl);
  }

  .content-section h2 {
    margin-bottom: var(--space-md);
  }

  .content-section p {
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: var(--space-md);
  }

  .content-section p:last-of-type {
    margin-bottom: 0;
  }

  .mission {
    background: linear-gradient(135deg, rgba(233, 69, 96, 0.08), rgba(244, 162, 97, 0.04));
    border: 1px solid rgba(233, 69, 96, 0.15);
  }

  .mission-text {
    font-size: 1.1rem;
    color: var(--color-text);
  }

  .mission-subtext {
    font-style: italic;
    padding-top: var(--space-md);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin-top: var(--space-md);
  }

  .values-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-lg);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-sm);
  }

  .values-list li {
    padding: var(--space-sm) var(--space-md);
    background: rgba(255, 255, 255, 0.03);
    border-radius: var(--radius-md);
    color: var(--color-text);
    text-align: center;
  }

  .values-note {
    font-style: italic;
    text-align: center;
    padding-top: var(--space-md);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .link-arrow {
    display: inline-block;
    color: var(--color-accent);
    font-weight: 500;
    margin-top: var(--space-md);
  }

  .link-arrow:hover {
    color: var(--color-accent-light);
  }

  .photo-gallery {
    margin-bottom: var(--space-xl);
  }

  .photo-gallery h2 {
    margin-bottom: var(--space-lg);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .gallery-item {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 16 / 10;
  }

  .gallery-item.featured {
    grid-column: span 2;
    grid-row: span 2;
    aspect-ratio: auto;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-normal);
  }

  .gallery-item:hover img {
    transform: scale(1.05);
  }

  .donate-section {
    background: linear-gradient(135deg, rgba(233, 69, 96, 0.1), rgba(244, 162, 97, 0.05));
    border: 1px solid rgba(233, 69, 96, 0.2);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .donate-section p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    line-height: 1.7;
  }

  .sponsors {
    margin-bottom: var(--space-xl);
  }

  .sponsors h2 {
    margin-bottom: var(--space-md);
  }

  .sponsor-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .sponsor {
    background: var(--color-card);
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    color: var(--color-text);
    text-decoration: none;
    transition: all var(--transition-fast);
    border: 1px solid transparent;
  }

  .sponsor:hover {
    background: var(--color-card-hover);
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateY(-2px);
  }

  .press-section {
    margin-bottom: var(--space-xl);
  }

  .press-section h2 {
    margin-bottom: var(--space-md);
  }

  .press-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .press-link {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md);
    background: var(--color-card);
    border-radius: var(--radius-md);
    color: var(--color-text);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .press-link:hover {
    background: var(--color-card-hover);
    transform: translateX(4px);
  }

  .press-icon {
    font-size: 1.5rem;
  }

  .split-section {
    display: grid;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
    align-items: stretch;
  }

  .split-45-55 {
    grid-template-columns: 45fr 55fr;
  }

  .split-55-45 {
    grid-template-columns: 55fr 45fr;
  }

  .split-section > .content-section {
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .gallery-item.featured {
      grid-column: span 2;
      grid-row: span 1;
      aspect-ratio: 16 / 9;
    }

    .content-section {
      padding: var(--space-lg);
    }

    .split-section {
      grid-template-columns: 1fr;
    }

    .values-list {
      grid-template-columns: 1fr;
    }
  }
</style>
